# ============================================================
# Louisiana Purchase — Environment Variable Reference
# Copy to .env for local development
# Copy to .env.production for production deployments
# NEVER commit .env or .env.production to version control
# ============================================================

# ─── Transactional Platform Links ────────────────────────────
PUBLIC_RESERVATIONS_URL=https://resy.com/cities/san-diego/venues/louisiana-purchase?utm_source=louisiana-purchase&utm_medium=website&utm_campaign=reservations
PUBLIC_ORDER_URL=https://order.toasttab.com/online/louisiana-purchase?utm_source=louisiana-purchase&utm_medium=website&utm_campaign=online-order
PUBLIC_GIFT_CARD_URL=https://order.toasttab.com/online/louisiana-purchase/giftcards?utm_source=louisiana-purchase&utm_medium=website&utm_campaign=gift-cards
# Private event inquiries no longer use a link-out platform (Tripleseat is retired) — the
# Toast lead-form iframe embed URL lives in src/data/events-config.ts instead, since it's
# the same value in every environment, not an operational endpoint that varies by deployment.

# ─── Analytics ───────────────────────────────────────────────
PUBLIC_GA_MEASUREMENT_ID=G-HSRHEQCBW8

