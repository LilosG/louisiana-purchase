# ─── Transactional Platform Links ────────────────────────────
PUBLIC_RESERVATIONS_URL=https://www.opentable.com/r/louisiana-purchase-sd-reservations-san-diego?restref=1039495&lang=en-US&ot_source=Restaurant%20website&utm_source=louisiana-purchase&utm_medium=website&utm_campaign=reservations
# Temporary during the Toast -> OpenTable migration: a small secondary "Reserve via Toast"
# button appears site-wide alongside the primary Reserve button until the client confirms
# OpenTable is working reliably, at which point this var and its buttons should be removed.
PUBLIC_RESERVATIONS_URL_TOAST=https://toast.app/r/louisiana-purchase?toast_sg=30bdef01-f4e0-4403-b50d-2b0263b663e1&toast_ss=8536cdf3-e37d-4e6e-89e6-3446ed13063d&toast_src=website_link&utm_source=louisiana-purchase&utm_medium=website&utm_campaign=reservations
PUBLIC_ORDER_URL=https://order.toasttab.com/online/louisiana-purchase?utm_source=louisiana-purchase&utm_medium=website&utm_campaign=online-order
PUBLIC_GIFT_CARD_URL=https://order.toasttab.com/online/louisiana-purchase/giftcards?utm_source=louisiana-purchase&utm_medium=website&utm_campaign=gift-cards
