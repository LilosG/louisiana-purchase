---
// src/pages/menu/dinner/index.astro
// Louisiana Purchase — Dinner Menu Page
// Targets: "creole dinner menu north park", "dinner restaurant san diego"

import Layout from '../../../layouts/Layout.astro';
import PageHero from '../../../components/ui/PageHero.astro';
import SectionHeader from '../../../components/ui/SectionHeader.astro';
import StatBar from '../../../components/ui/StatBar.astro';
import CTABand from '../../../components/ui/CTABand.astro';
import MenuShowcase from '../../../components/ui/MenuShowcase.astro';
import { IMAGES } from '../../../assets/images';
import { getSingleton } from '../../../content/siteData';

const page = await getSingleton('menuDinnerPage', 'page');
const venue = await getSingleton('venueSettings', 'settings');
const resolveCtas = (ctas: any[] = []) => (Array.isArray(ctas) ? ctas : []).map(({ url, ...cta }) => ({
  ...cta,
  href: url === 'reservations' ? (venue?.reservationsUrl || import.meta.env.PUBLIC_RESERVATIONS_URL)
      : url === 'reservations-toast' ? (venue?.reservationsUrlSecondary || import.meta.env.PUBLIC_RESERVATIONS_URL_TOAST)
      : url === 'order' ? (venue?.orderUrl || import.meta.env.PUBLIC_ORDER_URL)
      : cta.href,
}));

const dinnerSchema = {
  '@context': 'https://schema.org',
  '@type': 'Menu',
  name: page.seo.schemaName,
  description: page.seo.schemaDescription,
  url: `${import.meta.env.PUBLIC_SITE_URL || venue.domain}/menu/dinner`,
};
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
  canonical={page.seo.canonical}
  schema={dinnerSchema}
  breadcrumbs={page.seo.breadcrumbs}
>

  <PageHero
    {...page.hero}
    image={IMAGES[page.hero.image as keyof typeof IMAGES]}
    ctas={resolveCtas(page.hero.ctas)}
  />

  <StatBar
    stats={page.stats}
    dark={true}
  />

  <section aria-labelledby="dinner-menu-heading" class="bg-obsidian py-20 md:py-28">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader
        {...page.menuHeader}
      />

      <MenuShowcase section="food" cols={4} dark={true} divided={true} />

    </div>
  </section>

  <CTABand
    {...page.cta}
    image={IMAGES[page.cta.image as keyof typeof IMAGES]}
    ctas={resolveCtas(page.cta.ctas)}
  />

</Layout>
