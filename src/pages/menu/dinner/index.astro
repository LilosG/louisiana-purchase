---
// src/pages/menu/dinner/index.astro
// Louisiana Purchase — Dinner Menu Page
// Targets: "creole dinner menu north park", "dinner restaurant san diego"

import Layout from '../../../layouts/Layout.astro';
import PageHero from '../../../components/ui/PageHero.astro';
import SectionHeader from '../../../components/ui/SectionHeader.astro';
import StatBar from '../../../components/ui/StatBar.astro';
import CTABand from '../../../components/ui/CTABand.astro';
import MenuShowcase from '../../../components/ui/MenuShowcase.astro';
import { CANONICAL_DOMAIN, VENUE_ADDRESS } from '../../../data/venue';
import { IMAGES } from '../../../assets/images';

const dinnerSchema = {
  '@context': 'https://schema.org',
  '@type': 'Menu',
  name: 'Louisiana Purchase — Dinner Menu',
  description: "Chef Quinnton Austin's elevated Creole dinner menu at Louisiana Purchase in North Park, San Diego.",
  url: `${import.meta.env.PUBLIC_SITE_URL || CANONICAL_DOMAIN}/menu/dinner`,
};
---

<Layout
  title="Dinner Menu — Elevated Creole Kitchen | Louisiana Purchase North Park"
  description="Chef Quinnton Austin's elevated Creole dinner menu at Louisiana Purchase in North Park, San Diego. Fire-charred oysters, Louisiana BBQ shrimp, and slow-built gumbo, served daily."
  canonical="/menu/dinner"
  schema={dinnerSchema}
  breadcrumbs={[
    { name: 'Home',   url: '/',            position: 1 },
    { name: 'Menu',   url: '/menu',        position: 2 },
    { name: 'Dinner', url: '/menu/dinner', position: 3 },
  ]}
>

  <PageHero
    eyebrow="Open Daily"
    title="Dinner"
    titleItalic="Louisiana Purchase"
    subtitle="Chef Quinnton Austin's fire-forward Creole kitchen — fire-charred oysters, slow-built gumbo, and elevated Louisiana plates built for sharing."
    image={IMAGES['louisiana-purchase-modern-creole-restaurant-website']}
    imageAlt="Dinner at Louisiana Purchase North Park San Diego"
    ctas={[
      { label: 'Reserve a Table', href: import.meta.env.PUBLIC_RESERVATIONS_URL, external: true, variant: 'gold' },
      { label: 'Order Online',    href: import.meta.env.PUBLIC_ORDER_URL, external: true, variant: 'outline' },
    ]}
    headlineId="dinner-headline"
  />

  <StatBar
    stats={[
      { value: 'Daily', label: 'Dinner Service' },
      { value: 'Creole',    label: 'Cuisine' },
      { value: '$$$',       label: 'Price Range' },
      { value: '12 PM',    label: 'Earliest Open' },
    ]}
    dark={true}
  />

  <section aria-labelledby="dinner-menu-heading" class="bg-obsidian py-20 md:py-28">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader
        eyebrow="The Menu"
        title="Raw, Fire,"
        titleItalic="& Elevated Plates"
        subtitle="Chef Quinnton Austin's dinner program — fire-charred, slow-built, and obsessively precise."
        id="dinner-menu-heading"
      />

      <MenuShowcase section="food" cols={4} dark={true} divided={true} />

    </div>
  </section>

  <CTABand
    eyebrow="Ready to Dine"
    title="Reserve Your Table."
    subtitle={`Louisiana Purchase is open daily at ${VENUE_ADDRESS.street}. Walk-ins welcome at the bar.`}
    image={IMAGES['louisiana-purchase-dinner-north-park-san-diego-website']}
    ctas={[
      { label: 'Reserve a Table', href: import.meta.env.PUBLIC_RESERVATIONS_URL, external: true, variant: 'gold' },
      { label: 'Order Online',    href: import.meta.env.PUBLIC_ORDER_URL, external: true, variant: 'outline' },
    ]}
  />

</Layout>
