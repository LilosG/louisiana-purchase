---
import { getSingleton, resolveContent } from '../../content/siteData';
// src/pages/menu/index.astro
// Louisiana Purchase — Menu Hub Page
// Hub page linking to /menu/dinner, /menu/cocktails, /menu/brunch
// Targets: "menu north park", "creole restaurant menu san diego"

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import AlternatingRow from '../../components/ui/AlternatingRow.astro';
import StatBar from '../../components/ui/StatBar.astro';
import CTABand from '../../components/ui/CTABand.astro';
import FourColumnGrid from '../../components/ui/FourColumnGrid.astro';
import MenuShowcase from '../../components/ui/MenuShowcase.astro';
import { IMAGES } from '../../assets/images';
const pageContent = await getSingleton('menuIndexPage', 'page');
const blocks = pageContent.blocks.map((block: any) => resolveContent(block.props, IMAGES, import.meta.env));
---

<Layout {...blocks[0]}>

  <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
  <PageHero {...blocks[1]} />

  <!-- ─── Stat Bar ──────────────────────────────────────────────────────── -->
  <StatBar {...blocks[2]} />

  <!-- ─── Menu Sections Hub ────────────────────────────────────────────── -->
  <section aria-labelledby="menu-sections-heading" class="bg-obsidian py-20 md:py-28">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[3]} />

      <FourColumnGrid {...blocks[4]} />

    </div>
  </section>

  <!-- ─── Dinner Highlight ─────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[5]} />

  <!-- ─── Cocktails Highlight ──────────────────────────────────────────── -->
  <AlternatingRow {...blocks[6]} />

  <!-- ─── Brunch Highlight ─────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[7]} />

  <!-- ─── Featured Items ───────────────────────────────────────────────── -->
  <section aria-labelledby="featured-heading" class="bg-velvet py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[8]} />

      <MenuShowcase
        itemIds={['superbird-paloma', 'watermelon-margarita', 'dooky-chase', 'acme-oysters']}
        cols={4}
        dark={false}
        divided={true}
      />

    </div>
  </section>

  <!-- ─── CTA Band ──────────────────────────────────────────────────────── -->
  <CTABand {...blocks[9]} />

</Layout>
