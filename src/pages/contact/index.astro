---
import { getSingleton, resolveContent, buildEnv } from '../../content/siteData';
// src/pages/contact/index.astro
// Louisiana Purchase — Contact Page

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import CTABand from '../../components/ui/CTABand.astro';
import { IMAGES } from '../../assets/images';
const pageContent = await getSingleton('contactPage', 'page');
const venue = await getSingleton('venueSettings', 'settings');
const eventsConfig = await getSingleton('eventsConfig', 'config');
const VENUE_ADDRESS = venue.address;
const VENUE_MAPS_URL = venue.mapsUrl;
const VENUE_SOCIAL = venue.social;
const DISPLAY_HOURS = Array.isArray(venue.displayHours) ? venue.displayHours : [];
const BRUNCH_HOURS = venue.brunchHours;
const HAPPY_HOUR = venue.happyHour;
const PRIVATE_EVENTS_FORM_ANCHOR = eventsConfig.privateEventsFormAnchor;
const blocks = (Array.isArray(pageContent.blocks) ? pageContent.blocks : []).map((block: any) => resolveContent(block?.props ?? {}, IMAGES, buildEnv(venue, import.meta.env)));
const [reservations = {}, privateEvents = {}, orderOnline = {}] = Array.isArray(pageContent.contactMethods) ? pageContent.contactMethods : [];
const contactMethodHrefs: Record<string, string | undefined> = {
  reservations: venue?.reservationsUrl || import.meta.env.PUBLIC_RESERVATIONS_URL,
  reservationsToast: venue?.reservationsUrlSecondary || import.meta.env.PUBLIC_RESERVATIONS_URL_TOAST,
  privateEvents: `/private-events#${PRIVATE_EVENTS_FORM_ANCHOR}`,
  order: import.meta.env.PUBLIC_ORDER_URL,
};
const location = pageContent.location ?? {};
const locationBody = `\n${location.bodyPrefix ?? ''}${VENUE_ADDRESS.crossStreet}${location.bodyMiddle ?? ''}${VENUE_ADDRESS.neighborhood}${location.bodySuffix ?? ''}\n`;
---

<Layout {...blocks[0]}>

  <PageHero {...blocks[1]} />

  <!-- ─── Contact Grid ─────────────────────────────────────────────────── -->
  <section aria-labelledby="contact-methods-heading" class="bg-obsidian py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[2]} />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-gold/10">

        <!-- Reservations -->
        <div class="bg-obsidian-800 p-8 flex flex-col gap-4 reveal">
          <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold" set:text={reservations.eyebrow}></p>
          <h3 class="font-serif font-light text-parchment text-xl" set:text={reservations.title}></h3>
          <p class="font-sans font-light text-smoke text-sm leading-relaxed flex-1" set:text={`\n${reservations.body}\n`}></p>
          <a
            href={contactMethodHrefs[reservations.url]}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-6 py-3 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-[280ms] mt-auto"
            set:text={`\n${reservations.ctaLabel}\n`}
          ></a>
        </div>

        <!-- Private Events -->
        <div class="bg-obsidian-800 p-8 flex flex-col gap-4 reveal">
          <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold" set:text={privateEvents.eyebrow}></p>
          <h3 class="font-serif font-light text-parchment text-xl" set:text={privateEvents.title}></h3>
          <p class="font-sans font-light text-smoke text-sm leading-relaxed flex-1" set:text={`\n${privateEvents.body}\n`}></p>
          <a
            href={contactMethodHrefs[privateEvents.url]}
            class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-6 py-3 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-[280ms] mt-auto"
            set:text={`\n${privateEvents.ctaLabel}\n`}
          ></a>
        </div>

        <!-- Order Online -->
        <div class="bg-obsidian-800 p-8 flex flex-col gap-4 reveal">
          <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold" set:text={orderOnline.eyebrow}></p>
          <h3 class="font-serif font-light text-parchment text-xl" set:html={orderOnline.title}></h3>
          <p class="font-sans font-light text-smoke text-sm leading-relaxed flex-1" set:text={`\n${orderOnline.body}\n`}></p>
          <a
            href={contactMethodHrefs[orderOnline.url]}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-6 py-3 border border-gold/40 text-gold hover:border-gold hover:bg-gold/5 transition-all duration-[280ms] mt-auto"
            set:text={`\n${orderOnline.ctaLabel}\n`}
          ></a>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── Location & Hours ─────────────────────────────────────────────── -->
  <section aria-labelledby="location-hours-heading" class="bg-velvet py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

        <!-- Address & Directions -->
        <div>
          <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold mb-3" set:text={pageContent.location.eyebrow}></p>
          <h2 id="location-hours-heading" class="font-serif font-light text-parchment tracking-[-0.02em] leading-[1.05] mb-5" style="font-size: clamp(1.875rem, 3.5vw, 2.75rem);">
            {VENUE_ADDRESS.street}<br /><span class="italic text-gold">{VENUE_ADDRESS.neighborhood}, {VENUE_ADDRESS.city}</span>
          </h2>
          <p class="font-sans font-light text-smoke text-sm leading-relaxed mb-6 max-w-[40ch]" set:text={locationBody}></p>
          <a
            href={VENUE_MAPS_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-[280ms]"
            set:text={`\n${pageContent.location.ctaLabel}\n`}
          ></a>
        </div>

        <!-- Hours -->
        <div>
          <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold mb-3" set:text={pageContent.location.hoursEyebrow}></p>
          <dl class="flex flex-col gap-3 mb-6">
            {DISPLAY_HOURS.map((item: { label: string; value: string }) => (
              <div class="flex justify-between gap-8 py-3 border-b border-gold/10">
                <dt class="font-sans text-sm text-smoke/80 whitespace-nowrap">{item.label}</dt>
                <dd class="font-sans text-sm text-parchment whitespace-nowrap">{item.value}</dd>
              </div>
            ))}
          </dl>
          <p class="font-sans text-[0.75rem] text-gold/70 tracking-[0.04em]">
            {BRUNCH_HOURS.label}: {BRUNCH_HOURS.days} {BRUNCH_HOURS.window}<br />
            {HAPPY_HOUR.label}: {HAPPY_HOUR.days} {HAPPY_HOUR.window}
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── Social ───────────────────────────────────────────────────────── -->
  <section aria-labelledby="social-heading" class="bg-obsidian py-16 md:py-20">
    <div class="max-w-[1280px] mx-auto px-6 text-center">
      <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold mb-4" set:text={pageContent.social.eyebrow}></p>
      <h2 id="social-heading" class="font-serif font-light text-parchment tracking-[-0.02em] mb-6" style="font-size: clamp(1.5rem, 3vw, 2.25rem);" set:text={`\n${pageContent.social.title}\n`}></h2>
      <p class="font-sans font-light text-smoke text-sm leading-relaxed max-w-[44ch] mx-auto mb-8" set:text={`\n${pageContent.social.body}\n`}></p>
      <div class="flex justify-center gap-4">
        <a
          href={VENUE_SOCIAL.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 border border-gold/40 text-gold hover:border-gold hover:bg-gold/5 transition-all duration-[280ms]"
          set:text={`\n${pageContent.social.instagramLabel}\n`}
        ></a>
        <a
          href={VENUE_SOCIAL.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 border border-gold/40 text-gold hover:border-gold hover:bg-gold/5 transition-all duration-[280ms]"
          set:text={`\n${pageContent.social.facebookLabel}\n`}
        ></a>
      </div>
    </div>
  </section>

  <CTABand {...blocks[3]} />

</Layout>
