---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Louisiana Purchase — Creole Dining & Craft Cocktails | North Park, San Diego"
  description="An opulent French Quarter-inspired cocktail lounge and Creole dining destination in North Park, San Diego. Fire-charred oysters, Praline Old Fashioneds, and Chef Quinnton Austin's elevated Louisiana kitchen. Open Tuesday–Sunday."
  ogImage="/images/louisiana-purchase-north-park-restaurant-and-bar-website.jpg"
  ogType="website"
>

  <!-- ═══════════════════════════════════════════════════════════
       HERO — Full bleed night exterior. Louisiana St sign.
       ═══════════════════════════════════════════════════════════ -->
  <section
    aria-labelledby="hero-headline"
    class="site-hero"
  >
    <div class="site-hero__image-wrap" aria-hidden="true">
      <img
        src="/images/louisiana-purchase-north-park-restaurant-and-bar-website.jpg"
        alt="Louisiana Purchase at night — North Park, San Diego"
        class="site-hero__bg"
        width="1600"
        height="1064"
        fetchpriority="high"
        decoding="async"
      />
      <div class="site-hero__overlay"></div>
    </div>

    <div class="site-hero__content">
      <p class="eyebrow site-hero__eyebrow">North Park, San Diego</p>

      <h1 id="hero-headline" class="site-hero__headline">
        Louisiana<br />
        <em>Purchase</em>
      </h1>

      <p class="site-hero__sub">
        Elevated Creole cuisine. Complex craft cocktails.<br class="hidden md:block" />
        Chef Quinnton Austin's fire-forward Louisiana kitchen.
      </p>

      <div class="site-hero__ctas">
        <a
          href={import.meta.env.PUBLIC_RESERVATIONS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
          aria-label="Reserve a table at Louisiana Purchase"
        >
          Reserve a Table
        </a>
        <a
          href="/menu"
          class="btn-ghost"
          aria-label="View the Louisiana Purchase menu"
        >
          View the Menu
        </a>
      </div>
    </div>

    <!-- Quick-facts bar, identical pattern to Coco Maya / Lobby -->
    <div class="site-hero__facts" aria-label="Key venue information">
      <div class="hero-fact">
        <span class="hero-fact__label">Hours Today</span>
        <span class="hero-fact__value">5 PM – Close</span>
      </div>
      <div class="hero-fact hero-fact--link">
        <span class="hero-fact__label">Happy Hour</span>
        <a href="/happy-hour" class="hero-fact__value hero-fact__value--gold">
          Tue – Fri, 4–6 PM
        </a>
      </div>
      <div class="hero-fact hero-fact--link">
        <span class="hero-fact__label">Jazz Brunch</span>
        <a href="/brunch" class="hero-fact__value hero-fact__value--gold">
          Sat &amp; Sun, 10 AM – 3 PM
        </a>
      </div>
      <div class="hero-fact hero-fact--link">
        <span class="hero-fact__label">Location</span>
        <a
          href="https://maps.google.com/?q=3671+30th+St+San+Diego+CA+92104"
          target="_blank"
          rel="noopener noreferrer"
          class="hero-fact__value hero-fact__value--gold"
        >
          North Park, SD
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       ABOUT — Split layout. Interior bar shot + editorial copy.
       ═══════════════════════════════════════════════════════════ -->
  <section id="about" aria-labelledby="about-heading" class="section-about">

    <div class="about-grid">

      <div class="about-image-wrap animate-on-scroll">
        <img
          src="/images/louisiana-purchase-seafood-and-cocktails-north-park-website.jpg"
          alt="Louisiana Purchase interior bar — geometric wood ceiling and velvet seating, North Park San Diego"
          class="about-image"
          width="1600"
          height="1065"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="about-copy animate-on-scroll">
        <p class="eyebrow about-eyebrow">North Park, San Diego · Est. 2018</p>
        <h2 id="about-heading" class="about-heading">
          Where Little Italy's<br />
          Soul Moved<br />
          <span class="text-gold">to North Park</span>
        </h2>
        <p class="about-body">
          Louisiana Purchase is not a theme bar. It is a place — a genuine piece of
          New Orleans culture transplanted into the most vibrant neighborhood in San Diego.
          The geometric-timber ceiling, the candlelit bar, the patio framed by hanging
          ferns: every element earns its place.
        </p>
        <p class="about-body">
          Chef Quinnton Austin's kitchen is a love letter to Louisiana. Fire-charred oysters.
          Slow-built gumbo. Elevated Creole plates that honor the tradition without being
          imprisoned by it. The cocktail program — anchored by the Praline Old Fashioned
          and the Voo Doo Carré — demands reverence, not speed.
        </p>

        <dl class="about-facts">
          <div class="about-fact">
            <dt>Cuisine</dt>
            <dd>Elevated Creole</dd>
          </div>
          <div class="about-fact">
            <dt>Location</dt>
            <dd>North Park, SD</dd>
          </div>
          <div class="about-fact">
            <dt>Jazz Brunch</dt>
            <dd>Sat &amp; Sun</dd>
          </div>
          <div class="about-fact">
            <dt>Private Events</dt>
            <dd>Up to 80 Guests</dd>
          </div>
        </dl>

        <div class="about-ctas">
          <a href="/menu" class="btn-primary">See the Menu</a>
          <a href={import.meta.env.PUBLIC_RESERVATIONS_URL} target="_blank" rel="noopener noreferrer" class="btn-text-link">
            Reserve a Table →
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       SIGNATURE DRINKS — Horizontal card scroll
       ═══════════════════════════════════════════════════════════ -->
  <section aria-labelledby="cocktails-heading" class="section-cocktails">
    <div class="section-inner">

      <header class="section-header animate-on-scroll">
        <p class="eyebrow">Craft Program</p>
        <h2 id="cocktails-heading" class="section-title">
          Cocktails Built for<br />the French Quarter Soul
        </h2>
        <p class="section-subtitle">
          An obsessive bar program rooted in New Orleans tradition —
          complex, ceremonial, and utterly precise.
        </p>
      </header>

      <div class="cocktail-grid">

        <article class="cocktail-card animate-on-scroll">
          <div class="cocktail-card__image-wrap">
            <img
              src="/images/louisiana-purchase-cocktail-bar-north-park-website.jpg"
              alt="Craft cocktails at Louisiana Purchase — North Park San Diego bar"
              class="cocktail-card__image"
              width="1600"
              height="1066"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="cocktail-card__body">
            <p class="eyebrow cocktail-card__tag">Signature</p>
            <h3 class="cocktail-card__name">Praline Old Fashioned</h3>
            <p class="cocktail-card__desc">Buffalo Trace bourbon, house praline syrup, Peychaud's bitters, expressed orange peel</p>
            <p class="cocktail-card__price">$18</p>
          </div>
        </article>

        <article class="cocktail-card animate-on-scroll" style="animation-delay:80ms">
          <div class="cocktail-card__image-wrap">
            <img
              src="/images/louisiana-purchase-craft-cocktails-san-diego-website.jpg"
              alt="Craft cocktails and oysters at Louisiana Purchase San Diego"
              class="cocktail-card__image"
              width="1600"
              height="1060"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="cocktail-card__body">
            <p class="eyebrow cocktail-card__tag">Chef's Selection</p>
            <h3 class="cocktail-card__name">Voo Doo Carré</h3>
            <p class="cocktail-card__desc">Rye whiskey, cognac, sweet vermouth, Bénédictine, house Creole bitters</p>
            <p class="cocktail-card__price">$19</p>
          </div>
        </article>

        <article class="cocktail-card animate-on-scroll" style="animation-delay:160ms">
          <div class="cocktail-card__image-wrap">
            <img
              src="/images/louisiana-purchase-happy-hour-north-park-website.jpg"
              alt="Happy hour cocktails at Louisiana Purchase North Park"
              class="cocktail-card__image"
              width="1600"
              height="2400"
              loading="lazy"
              decoding="async"
              style="object-position: center 30%"
            />
          </div>
          <div class="cocktail-card__body">
            <p class="eyebrow cocktail-card__tag">Happy Hour</p>
            <h3 class="cocktail-card__name">Bayou Swizzle</h3>
            <p class="cocktail-card__desc">Agricole rhum, passion fruit, fresh lime, orgeat, mint, Angostura</p>
            <p class="cocktail-card__price">$17</p>
          </div>
        </article>

        <article class="cocktail-card animate-on-scroll" style="animation-delay:240ms">
          <div class="cocktail-card__image-wrap">
            <img
              src="/images/louisiana-purchase-date-night-north-park-website.jpg"
              alt="Louisiana Purchase bar through garden foliage — moody date night atmosphere"
              class="cocktail-card__image"
              width="1600"
              height="1080"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="cocktail-card__body">
            <p class="eyebrow cocktail-card__tag">The Bar</p>
            <h3 class="cocktail-card__name">The Full Program</h3>
            <p class="cocktail-card__desc">An extensive selection of Louisiana-inspired cocktails, curated spirits, and wine</p>
            <a href="/menu" class="cocktail-card__link">Full Menu →</a>
          </div>
        </article>

      </div>

      <div class="section-cta-row animate-on-scroll">
        <a href="/menu" class="btn-primary">Full Cocktail Menu</a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       BRUNCH — Full-width image + text overlay, identical to
       Coco Maya brunch section treatment
       ═══════════════════════════════════════════════════════════ -->
  <section aria-labelledby="brunch-heading" class="section-brunch">
    <div class="brunch-image-wrap" aria-hidden="true">
      <img
        src="/images/louisiana-purchase-brunch-north-park-san-diego-website.jpg"
        alt="Jazz brunch at Louisiana Purchase — North Park San Diego"
        class="brunch-bg"
        width="1600"
        height="1071"
        loading="lazy"
        decoding="async"
      />
      <div class="brunch-overlay"></div>
    </div>
    <div class="brunch-content animate-on-scroll">
      <p class="eyebrow brunch-eyebrow">Saturday &amp; Sunday · 10 AM – 3 PM</p>
      <h2 id="brunch-heading" class="brunch-heading">
        Jazz Brunch<br />
        <em>in North Park</em>
      </h2>
      <p class="brunch-body">
        San Diego's most indulgent weekend ritual. Live jazz, Creole brunch plates,
        and craft cocktails from 10am. The patio, the music, the morning light through
        the pergola — come early. Stay late.
      </p>
      <div class="brunch-ctas">
        <a href={import.meta.env.PUBLIC_RESERVATIONS_URL} target="_blank" rel="noopener noreferrer" class="btn-primary">
          Reserve for Brunch
        </a>
        <a href="/brunch" class="btn-ghost">See the Brunch Menu</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FOOD — 4-card grid
       ═══════════════════════════════════════════════════════════ -->
  <section aria-labelledby="food-heading" class="section-food">
    <div class="section-inner">

      <header class="section-header animate-on-scroll">
        <p class="eyebrow">The Kitchen</p>
        <h2 id="food-heading" class="section-title">
          Food Worth<br />Staying For
        </h2>
        <p class="section-subtitle">
          Chef Quinnton Austin's elevated Creole program —
          fire-forward, deeply rooted, and obsessively precise.
        </p>
      </header>

      <div class="food-grid">

        <article class="food-card food-card--wide animate-on-scroll">
          <div class="food-card__image-wrap">
            <img
              src="/images/louisiana-purchase-creole-cuisine-north-park-website.jpg"
              alt="Lobster pasta and fire-charred oysters — Louisiana Purchase Creole cuisine North Park"
              class="food-card__image"
              width="1600"
              height="1060"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="food-card__body">
            <p class="eyebrow food-card__tag">Signature</p>
            <h3 class="food-card__name">Lobster Pasta</h3>
            <p class="food-card__desc">Half-shell lobster, house Creole cream sauce, toasted breadcrumb</p>
          </div>
        </article>

        <article class="food-card animate-on-scroll" style="animation-delay:80ms">
          <div class="food-card__image-wrap">
            <img
              src="/images/louisiana-purchase-group-dining-san-diego-website.jpg"
              alt="Fire-charred oysters at Louisiana Purchase — San Diego Creole restaurant"
              class="food-card__image"
              width="1600"
              height="2400"
              loading="lazy"
              decoding="async"
              style="object-position: center 40%"
            />
          </div>
          <div class="food-card__body">
            <p class="eyebrow food-card__tag">Raw &amp; Fire</p>
            <h3 class="food-card__name">Fire-Charred Oysters</h3>
            <p class="food-card__desc">House compound butter, parsley gremolata, toasted breadcrumb</p>
          </div>
        </article>

        <article class="food-card animate-on-scroll" style="animation-delay:160ms">
          <div class="food-card__image-wrap">
            <img
              src="/images/louisiana-purchase-dinner-north-park-san-diego-website.jpg"
              alt="Elevated Creole dinner plates at Louisiana Purchase North Park"
              class="food-card__image"
              width="1600"
              height="2400"
              loading="lazy"
              decoding="async"
              style="object-position: center 30%"
            />
          </div>
          <div class="food-card__body">
            <p class="eyebrow food-card__tag">The Kitchen</p>
            <h3 class="food-card__name">Steak Étouffée</h3>
            <p class="food-card__desc">Fire-seared ribeye, house crawfish étouffée, roasted garlic</p>
          </div>
        </article>

        <article class="food-card animate-on-scroll" style="animation-delay:240ms">
          <div class="food-card__image-wrap">
            <img
              src="/images/louisiana-purchase-modern-creole-restaurant-website.jpg"
              alt="Modern Creole cuisine at Louisiana Purchase — North Park San Diego"
              class="food-card__image"
              width="1600"
              height="2381"
              loading="lazy"
              decoding="async"
              style="object-position: center 35%"
            />
          </div>
          <div class="food-card__body">
            <p class="eyebrow food-card__tag">Chef's Selection</p>
            <h3 class="food-card__name">Creole Crab Cake</h3>
            <p class="food-card__desc">Jumbo lump, house remoulade, shaved fennel, pickled mustard seed</p>
          </div>
        </article>

      </div>

      <div class="section-cta-row animate-on-scroll">
        <a href="/menu" class="btn-primary">Full Food Menu</a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       PRIVATE EVENTS — Full-width image split
       ═══════════════════════════════════════════════════════════ -->
  <section aria-labelledby="events-heading" class="section-events">

    <div class="events-image-col" aria-hidden="true">
      <img
        src="/images/louisiana-purchase-private-dining-san-diego-website.jpg"
        alt="Private dining at Louisiana Purchase — intimate venue in North Park San Diego"
        class="events-image"
        width="1600"
        height="1066"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="events-copy-col animate-on-scroll">
      <p class="eyebrow">Group Bookings</p>
      <h2 id="events-heading" class="events-heading">
        Private Events<br />
        <em>in North Park</em>
      </h2>
      <p class="events-body">
        Birthdays, corporate dinners, rehearsal events, and full venue buyouts.
        Louisiana Purchase provides a backdrop that your guests will actually talk about.
      </p>
      <ul class="events-list" role="list">
        <li>Corporate Dinners &amp; Executive Events</li>
        <li>Birthday &amp; Milestone Celebrations</li>
        <li>Rehearsal Dinners</li>
        <li>Full Venue &amp; Patio Buyouts</li>
        <li>Jazz Brunch Buyouts</li>
      </ul>
      <a
        href={import.meta.env.PUBLIC_PRIVATE_EVENTS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
        aria-label="Inquire about private events at Louisiana Purchase"
      >
        Inquire About Your Event
      </a>
    </div>

  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FIND US — Stats bar + map CTA, identical to Lobby pattern
       ═══════════════════════════════════════════════════════════ -->
  <section aria-labelledby="find-us-heading" class="section-find-us">
    <div class="section-inner">

      <div class="stats-bar animate-on-scroll">
        <div class="stat-item">
          <span class="stat-value">4.6★</span>
          <span class="stat-label">Google Rating</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">80+</span>
          <span class="stat-label">Event Capacity</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">20+</span>
          <span class="stat-label">Craft Cocktails</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">Tue–Sun</span>
          <span class="stat-label">Open Weekly</span>
        </div>
      </div>

      <div class="find-us-grid animate-on-scroll">

        <div class="find-us-image-wrap">
          <img
            src="/images/louisiana-purchase-seafood-restaurant-san-diego-website.jpg"
            alt="Louisiana Purchase exterior — 3671 30th St, North Park San Diego"
            class="find-us-image"
            width="1600"
            height="1068"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="find-us-details">
          <p class="find-us-cross">30th St × University Ave</p>
          <p class="find-us-neighborhood">North Park · San Diego</p>
          <h2 id="find-us-heading" class="find-us-address">3671 30th St</h2>
          <p class="find-us-city">North Park, San Diego, CA 92104</p>

          <dl class="find-us-hours">
            <div class="find-us-hour-row">
              <dt>Tuesday – Friday</dt>
              <dd>5 PM – Close</dd>
            </div>
            <div class="find-us-hour-row">
              <dt>Saturday</dt>
              <dd>10 AM – Close</dd>
            </div>
            <div class="find-us-hour-row">
              <dt>Sunday</dt>
              <dd>10 AM – 10 PM</dd>
            </div>
            <div class="find-us-hour-row">
              <dt>Monday</dt>
              <dd>Closed</dd>
            </div>
          </dl>

          <div class="find-us-ctas">
            <a
              href="https://maps.google.com/?q=3671+30th+St+San+Diego+CA+92104"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              Get Directions
            </a>
            <a
              href={`tel:${import.meta.env.PUBLIC_VENUE_PHONE}`}
              class="btn-text-link"
            >
              {import.meta.env.PUBLIC_VENUE_PHONE}
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
/* ═══════════════════════════════════════════════════════════════
   HOMEPAGE COMPONENT STYLES
   All values map to tokens defined in tailwind.config.mjs
   and CSS custom properties in global.css.
   Zero arbitrary values.
   ═══════════════════════════════════════════════════════════════ */

/* ─── Hero ─────────────────────────────────────────────────── */
.site-hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
}

.site-hero__image-wrap {
  position: absolute;
  inset: 0;
}

.site-hero__bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 60%;
  display: block;
}

.site-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(10,8,6,0.25) 0%,
    rgba(10,8,6,0.15) 40%,
    rgba(10,8,6,0.85) 80%,
    rgba(10,8,6,0.98) 100%
  );
}

.site-hero__content {
  position: relative;
  z-index: 10;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 1.5rem 7rem;
  width: 100%;
}

.site-hero__eyebrow {
  margin-bottom: 1.5rem;
  animation: fade-up 0.8s cubic-bezier(0.16,1,0.3,1) both;
}

.site-hero__headline {
  font-family: var(--font-display);
  font-size: clamp(3.5rem, 10vw, 9rem);
  font-weight: 300;
  line-height: 0.92;
  letter-spacing: -0.03em;
  color: var(--color-parchment);
  margin-bottom: 1.5rem;
  animation: fade-up 0.8s cubic-bezier(0.16,1,0.3,1) 80ms both;
}

.site-hero__headline em {
  font-style: italic;
  background: linear-gradient(135deg, #C9A84C 0%, #EDD07A 50%, #B8922F 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  display: block;
}

.site-hero__sub {
  font-family: var(--font-serif);
  font-size: clamp(1rem, 2vw, 1.25rem);
  font-weight: 300;
  font-style: italic;
  color: rgba(242,235,224,0.72);
  max-width: 52ch;
  margin-bottom: 2.5rem;
  line-height: 1.6;
  animation: fade-up 0.8s cubic-bezier(0.16,1,0.3,1) 160ms both;
}

.site-hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  animation: fade-up 0.8s cubic-bezier(0.16,1,0.3,1) 240ms both;
}

/* Hero facts bar */
.site-hero__facts {
  position: relative;
  z-index: 10;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  border-top: 1px solid rgba(201,168,76,0.20);
  background: rgba(10,8,6,0.82);
  backdrop-filter: blur(8px);
}

@media (min-width: 768px) {
  .site-hero__facts {
    grid-template-columns: repeat(4, 1fr);
  }
}

.hero-fact {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  padding: 1.25rem 1.5rem;
  border-right: 1px solid rgba(201,168,76,0.12);
}

.hero-fact:last-child { border-right: none; }

.hero-fact__label {
  font-family: var(--font-sans);
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--color-smoke);
}

.hero-fact__value {
  font-family: var(--font-sans);
  font-size: 0.875rem;
  font-weight: 400;
  color: var(--color-parchment);
}

.hero-fact__value--gold {
  color: var(--color-gold);
  transition: color 280ms ease;
}

.hero-fact__value--gold:hover { color: #EDD07A; }

/* ─── Shared Buttons ────────────────────────────────────────── */
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.875rem 2rem;
  background: var(--color-gold);
  color: var(--color-obsidian);
  font-family: var(--font-sans);
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  border-radius: 2px;
