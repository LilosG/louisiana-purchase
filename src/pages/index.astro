---
import { getSingleton, resolveContent, buildEnv } from '../content/siteData';
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/ui/PageHero.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import AlternatingRow from '../components/ui/AlternatingRow.astro';
import StatBar from '../components/ui/StatBar.astro';
import CTABand from '../components/ui/CTABand.astro';
import MenuShowcase from '../components/ui/MenuShowcase.astro';
import { IMAGES } from '../assets/images';

const pageContent = await getSingleton('home', 'home');
const venue = await getSingleton('venueSettings', 'settings');
const blocks = (Array.isArray(pageContent.blocks) ? pageContent.blocks : []).map((block: any) => resolveContent(block?.props ?? {}, IMAGES, buildEnv(venue, import.meta.env)));
---

<Layout {...blocks[0]}>

  <!-- ─── HERO ──────────────────────────────────────────────── -->
  <PageHero {...blocks[1]} />

  <StatBar {...blocks[2]} />

  <!-- ─── ABOUT ────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[3]} />

  <!-- ─── COCKTAILS ─────────────────────────────────────────── -->
  <section aria-labelledby="cocktails-h" class="bg-obsidian py-20 md:py-28">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[4]} />

      <MenuShowcase section="cocktails" featuredOnly={true} limit={4} cols={4} dark={true} divided={true} />

      <div class="text-center mt-10">
        <a href={pageContent.menuLinks.cocktails.href} class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-[280ms]" set:text={`\n${pageContent.menuLinks.cocktails.label}\n`}></a>
      </div>
    </div>
  </section>

  <!-- ─── BRUNCH ────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[5]} />

  <!-- ─── FOOD STRIP ────────────────────────────────────────── -->
  <section aria-labelledby="dish-h" class="bg-obsidian py-20 md:py-28">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[6]} />

      <MenuShowcase
        itemIds={['dragos', 'creole-shrimp-pasta', 'lemon-pepper-catfish', 'steak-monica']}
        cols={4}
        dark={true}
        divided={true}
      />

      <div class="text-center mt-10">
        <a href={pageContent.menuLinks.dinner.href} class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-[280ms]" set:text={`\n${pageContent.menuLinks.dinner.label}\n`}></a>
      </div>
    </div>
  </section>

  <!-- ─── PRIVATE EVENTS ────────────────────────────────────── -->
  <AlternatingRow {...blocks[7]}>
    <ul role="list" class="flex flex-col gap-2.5 mt-2 mb-8">
      {(Array.isArray(pageContent.privateEventHighlights) ? pageContent.privateEventHighlights : []).map((item: string) => (
        <li class="flex items-start gap-3 font-sans text-sm text-parchment/70">
          <span class="text-gold text-[0.5rem] mt-1.5 shrink-0">{pageContent.listMarker}</span>
          {item}
        </li>
      ))}
    </ul>
  </AlternatingRow>

  <!-- ─── FIND US ────────────────────────────────────────────── -->
  <StatBar {...blocks[8]} />

  <AlternatingRow {...blocks[9]} />

  <CTABand {...blocks[10]} />

</Layout>
