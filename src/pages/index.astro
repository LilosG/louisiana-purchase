---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Louisiana Purchase — Creole Dining & Craft Cocktails | North Park, San Diego"
  description="An opulent French Quarter-inspired cocktail lounge and Creole dining destination in North Park, San Diego. Fire-charred oysters, Praline Old Fashioneds, and Chef Quinnton Austin's elevated Louisiana kitchen. Open Tuesday–Sunday."
  ogImage="/images/louisiana-purchase-north-park-restaurant-and-bar-website.jpg"
  ogType="website"
>

<!-- ═══════════════════════════════════
     HERO
═══════════════════════════════════ -->
<section class="hero" aria-labelledby="hero-headline">
  <div class="hero__media" aria-hidden="true">
    <img
      src="/images/louisiana-purchase-north-park-restaurant-and-bar-website.jpg"
      alt="Louisiana Purchase at night — North Park, San Diego"
      class="hero__img"
      width="1600" height="1064"
      fetchpriority="high" decoding="async"
    />
    <div class="hero__scrim"></div>
  </div>

  <div class="hero__body">
    <p class="lp-eyebrow hero__eyebrow">North Park, San Diego</p>
    <h1 id="hero-headline" class="hero__title">
      Louisiana<br /><em>Purchase</em>
    </h1>
    <p class="hero__sub">
      Elevated Creole cuisine &amp; complex craft cocktails.<br class="md-break" />
      Chef Quinnton Austin's fire-forward Louisiana kitchen.
    </p>
    <div class="hero__ctas">
      <a href={import.meta.env.PUBLIC_RESERVATIONS_URL} target="_blank" rel="noopener noreferrer" class="btn-gold">Reserve a Table</a>
      <a href="/menu" class="btn-outline">View the Menu</a>
    </div>
  </div>

  <div class="hero__bar" aria-label="Key venue information">
    <div class="hbar-item">
      <span class="hbar-label">Hours Today</span>
      <span class="hbar-val">5 PM – Close</span>
    </div>
    <div class="hbar-item">
      <span class="hbar-label">Happy Hour</span>
      <a href="/happy-hour" class="hbar-val hbar-val--link">Tue – Fri, 4–6 PM</a>
    </div>
    <div class="hbar-item">
      <span class="hbar-label">Jazz Brunch</span>
      <a href="/brunch" class="hbar-val hbar-val--link">Sat &amp; Sun, 10 AM</a>
    </div>
    <div class="hbar-item">
      <span class="hbar-label">Location</span>
      <a href="https://maps.google.com/?q=3671+30th+St+San+Diego+CA+92104" target="_blank" rel="noopener noreferrer" class="hbar-val hbar-val--link">North Park, SD</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════
     ABOUT — split layout
═══════════════════════════════════ -->
<section id="about" class="about" aria-labelledby="about-h">
  <div class="about__img-col reveal">
    <img
      src="/images/louisiana-purchase-seafood-and-cocktails-north-park-website.jpg"
      alt="Louisiana Purchase interior — geometric timber ceiling, marble bar, velvet seating"
      class="about__img"
      width="1600" height="1065"
      loading="lazy" decoding="async"
    />
  </div>
  <div class="about__copy reveal">
    <p class="lp-eyebrow">North Park, San Diego · Est. 2018</p>
    <h2 id="about-h" class="about__title">
      Where New Orleans<br />Found Its Way<br /><span class="gold-text">to North Park</span>
    </h2>
    <p class="about__body">Louisiana Purchase is not a theme bar. It is a place — a genuine piece of New Orleans culture transplanted into San Diego's most vibrant neighborhood. The geometric timber ceiling, the candlelit bar, the patio framed by hanging ferns: every element earns its place.</p>
    <p class="about__body">Chef Quinnton Austin's kitchen is a love letter to Louisiana. Fire-charred oysters. Slow-built gumbo. Elevated Creole plates that honor the tradition without being imprisoned by it. The cocktail program demands reverence, not speed.</p>
    <dl class="about__facts">
      <div><dt>Cuisine</dt><dd>Elevated Creole</dd></div>
      <div><dt>Location</dt><dd>North Park, SD</dd></div>
      <div><dt>Jazz Brunch</dt><dd>Sat &amp; Sun</dd></div>
      <div><dt>Private Events</dt><dd>Up to 80 Guests</dd></div>
    </dl>
    <div class="about__ctas">
      <a href="/menu" class="btn-gold">See the Menu</a>
      <a href={import.meta.env.PUBLIC_RESERVATIONS_URL} target="_blank" rel="noopener noreferrer" class="btn-text">Reserve a Table →</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════
     COCKTAILS
═══════════════════════════════════ -->
<section class="cocktails" aria-labelledby="cocktails-h">
  <div class="section-wrap">
    <header class="section-hd reveal">
      <p class="lp-eyebrow">Craft Program</p>
      <h2 id="cocktails-h" class="section-title">Cocktails Built for<br />the French Quarter Soul</h2>
      <p class="section-sub">An obsessive bar program rooted in New Orleans tradition — complex, ceremonial, and utterly precise.</p>
    </header>

    <div class="cocktails__grid">
      <article class="ccard reveal">
        <div class="ccard__img-wrap">
          <img src="/images/louisiana-purchase-intimate-cocktail-restaurant-website.jpg"
            alt="Praline Old Fashioned — Louisiana Purchase signature cocktail on reclaimed wood pedestal"
            class="ccard__img" width="1600" height="2408" loading="lazy" decoding="async" style="object-position:center 20%" />
        </div>
        <div class="ccard__body">
          <p class="lp-eyebrow ccard__tag">Signature</p>
          <h3 class="ccard__name">Praline Old Fashioned</h3>
          <p class="ccard__desc">Buffalo Trace bourbon, house praline syrup, Peychaud's bitters, expressed orange peel</p>
          <p class="ccard__price">$18</p>
        </div>
      </article>

      <article class="ccard reveal" style="animation-delay:80ms">
        <div class="ccard__img-wrap">
          <img src="/images/louisiana-purchase-drink-menu-north-park-san-diego-website.jpg"
            alt="Voo Doo Carré — Louisiana Purchase craft cocktail"
            class="ccard__img" width="1600" height="2393" loading="lazy" decoding="async" style="object-position:center 25%" />
        </div>
        <div class="ccard__body">
          <p class="lp-eyebrow ccard__tag">Chef's Selection</p>
          <h3 class="ccard__name">Voo Doo Carré</h3>
          <p class="ccard__desc">Rye whiskey, cognac, sweet vermouth, Bénédictine, house Creole bitters</p>
          <p class="ccard__price">$19</p>
        </div>
      </article>

      <article class="ccard reveal" style="animation-delay:160ms">
        <div class="ccard__img-wrap">
          <img src="/images/louisiana-purchase-cocktail-menu-north-park-website.jpg"
            alt="Beignet espresso martini — Louisiana Purchase bar program"
            class="ccard__img" width="1600" height="2400" loading="lazy" decoding="async" style="object-position:center 30%" />
        </div>
        <div class="ccard__body">
          <p class="lp-eyebrow ccard__tag">Bar Exclusive</p>
          <h3 class="ccard__name">Café Brûlot Martini</h3>
          <p class="ccard__desc">Cold-brew spirit, house café brûlot syrup, egg white, beignet garnish</p>
          <p class="ccard__price">$17</p>
        </div>
      </article>

      <article class="ccard reveal" style="animation-delay:240ms">
        <div class="ccard__img-wrap">
          <img src="/images/louisiana-purchase-patio-dining-north-park-website.jpg"
            alt="Craft cocktail at Louisiana Purchase patio — North Park San Diego"
            class="ccard__img" width="1600" height="2412" loading="lazy" decoding="async" style="object-position:center 20%" />
        </div>
        <div class="ccard__body">
          <p class="lp-eyebrow ccard__tag">The Bar</p>
          <h3 class="ccard__name">Bayou Swizzle</h3>
          <p class="ccard__desc">Agricole rhum, passion fruit, fresh lime, orgeat, mint, Angostura</p>
          <a href="/menu" class="ccard__link">Full Menu →</a>
        </div>
      </article>
    </div>

    <div class="section-cta reveal">
      <a href="/menu" class="btn-gold">Full Cocktail Menu</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════
     BRUNCH — full-bleed
═══════════════════════════════════ -->
<section class="brunch" aria-labelledby="brunch-h">
  <div class="brunch__media" aria-hidden="true">
    <img
      src="/images/louisiana-purchase-cajun-creole-menu-san-diego-website.jpg"
      alt="Jazz brunch — gumbo with crab claws and trumpet, Louisiana Purchase North Park"
      class="brunch__img"
      width="1600" height="2381"
      loading="lazy" decoding="async"
      style="object-position:center 30%"
    />
    <div class="brunch__scrim"></div>
  </div>
  <div class="brunch__content reveal">
    <p class="lp-eyebrow">Saturday &amp; Sunday · 10 AM – 3 PM</p>
    <h2 id="brunch-h" class="brunch__title">Jazz Brunch<br /><em>in North Park</em></h2>
    <p class="brunch__body">San Diego's most indulgent weekend ritual. Live jazz, Creole brunch plates, and craft cocktails from 10am. The patio, the music, the morning light through the pergola — come early. Stay late.</p>
    <div class="brunch__ctas">
      <a href={import.meta.env.PUBLIC_RESERVATIONS_URL} target="_blank" rel="noopener noreferrer" class="btn-gold">Reserve for Brunch</a>
      <a href="/brunch" class="btn-outline">See the Brunch Menu</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════
     FOOD GRID
═══════════════════════════════════ -->
<section class="food" aria-labelledby="food-h">
  <div class="section-wrap">
    <header class="section-hd reveal">
      <p class="lp-eyebrow">The Kitchen</p>
      <h2 id="food-h" class="section-title">Food Worth<br />Staying For</h2>
      <p class="section-sub">Chef Quinnton Austin's elevated Creole program — fire-forward, deeply rooted, obsessively precise.</p>
    </header>

    <div class="food__grid">
      <article class="fcard fcard--tall reveal">
        <div class="fcard__img-wrap">
          <img src="/images/louisiana-purchase-creole-cuisine-north-park-website.jpg"
            alt="Lobster pasta and fire-charred oysters — Louisiana Purchase Creole cuisine"
            class="fcard__img" width="1600" height="1060" loading="lazy" decoding="async" />
        </div>
        <div class="fcard__body">
          <p class="lp-eyebrow fcard__tag">Signature</p>
          <h3 class="fcard__name">Lobster Pasta</h3>
          <p class="fcard__desc">Half-shell lobster, Creole cream, toasted breadcrumb</p>
        </div>
      </article>

      <article class="fcard reveal" style="animation-delay:60ms">
        <div class="fcard__img-wrap">
          <img src="/images/louisiana-purchase-group-dining-san-diego-website.jpg"
            alt="Fire-charred oysters at Louisiana Purchase"
            class="fcard__img" width="1600" height="2400" loading="lazy" decoding="async" style="object-position:center 35%" />
        </div>
        <div class="fcard__body">
          <p class="lp-eyebrow fcard__tag">Raw &amp; Fire</p>
          <h3 class="fcard__name">Fire-Charred Oysters</h3>
          <p class="fcard__desc">Compound butter, parsley gremolata, breadcrumb</p>
        </div>
      </article>

      <article class="fcard reveal" style="animation-delay:120ms">
        <div class="fcard__img-wrap">
          <img src="/images/louisiana-purchase-weekend-brunch-san-diego-website.jpg"
            alt="Weekend brunch at Louisiana Purchase North Park San Diego"
            class="fcard__img" width="1600" height="2387" loading="lazy" decoding="async" style="object-position:center 25%" />
        </div>
        <div class="fcard__body">
          <p class="lp-eyebrow fcard__tag">Weekend Brunch</p>
          <h3 class="fcard__name">Banana Foster French Toast</h3>
          <p class="fcard__desc">Caramelized bananas, bourbon butter sauce, powdered sugar</p>
        </div>
      </article>

      <article class="fcard reveal" style="animation-delay:180ms">
        <div class="fcard__img-wrap">
          <img src="/images/louisiana-purchase-dinner-north-park-san-diego-website.jpg"
            alt="Steak étouffée — elevated Creole dinner at Louisiana Purchase"
            class="fcard__img" width="1600" height="2400" loading="lazy" decoding="async" style="object-position:center 25%" />
        </div>
        <div class="fcard__body">
          <p class="lp-eyebrow fcard__tag">The Kitchen</p>
          <h3 class="fcard__name">Steak Étouffée</h3>
          <p class="fcard__desc">Fire-seared ribeye, crawfish étouffée, roasted garlic</p>
        </div>
      </article>
    </div>

    <div class="section-cta reveal">
      <a href="/menu" class="btn-gold">Full Food Menu</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════
     MOOD BREAK — "eat me" neon
═══════════════════════════════════ -->
<div class="mood-break" aria-hidden="true">
  <img
    src="/images/louisiana-purchase-new-orleans-inspired-bar-north-park-website.jpg"
    alt=""
    class="mood-break__img"
    width="1600" height="2593"
    loading="lazy" decoding="async"
    style="object-position:center 15%"
  />
  <div class="mood-break__scrim"></div>
</div>

<!-- ═══════════════════════════════════
     PRIVATE EVENTS
═══════════════════════════════════ -->
<section class="events" aria-labelledby="events-h">
  <div class="events__img-col">
    <img
      src="/images/louisiana-purchase-private-dining-san-diego-website.jpg"
      alt="Private dining at Louisiana Purchase North Park San Diego"
      class="events__img"
      width="1600" height="1066"
      loading="lazy" decoding="async"
    />
  </div>
  <div class="events__copy reveal">
    <p class="lp-eyebrow">Group Bookings</p>
    <h2 id="events-h" class="events__title">Private Events<br /><em>in North Park</em></h2>
    <p class="events__body">Birthdays, corporate dinners, rehearsal events, and full venue buyouts. Louisiana Purchase provides a backdrop your guests will actually talk about.</p>
    <ul class="events__list" role="list">
      <li>Corporate Dinners &amp; Executive Events</li>
      <li>Birthday &amp; Milestone Celebrations</li>
      <li>Rehearsal Dinners</li>
      <li>Full Venue &amp; Patio Buyouts</li>
      <li>Jazz Brunch Buyouts</li>
    </ul>
    <a href={import.meta.env.PUBLIC_PRIVATE_EVENTS_URL} target="_blank" rel="noopener noreferrer" class="btn-gold">Inquire About Your Event</a>
  </div>
</section>

<!-- ═══════════════════════════════════
     FIND US
═══════════════════════════════════ -->
<section class="findus" aria-labelledby="findus-h">
  <div class="section-wrap">
    <div class="stats-row reveal">
      <div class="stat"><span class="stat__val">4.6★</span><span class="stat__lbl">Google Rating</span></div>
      <div class="stat"><span class="stat__val">80+</span><span class="stat__lbl">Event Capacity</span></div>
      <div class="stat"><span class="stat__val">20+</span><span class="stat__lbl">Craft Cocktails</span></div>
      <div class="stat"><span class="stat__val">Tue–Sun</span><span class="stat__lbl">Open Weekly</span></div>
    </div>

    <div class="findus__grid reveal">
      <div class="findus__img-wrap">
        <img
          src="/images/louisiana-purchase-seafood-restaurant-san-diego-website.jpg"
          alt="Louisiana Purchase exterior — 3671 30th St North Park San Diego"
          class="findus__img"
          width="1600" height="1068"
          loading="lazy" decoding="async"
        />
      </div>
      <div class="findus__details">
        <p class="findus__cross">30th St × University Ave</p>
        <p class="lp-eyebrow findus__hood">North Park · San Diego</p>
        <h2 id="findus-h" class="findus__addr">3671 30th St</h2>
        <p class="findus__city">North Park, San Diego, CA 92104</p>
        <dl class="findus__hours">
          <div><dt>Tuesday – Friday</dt><dd>5 PM – Close</dd></div>
          <div><dt>Saturday</dt><dd>10 AM – Close</dd></div>
          <div><dt>Sunday</dt><dd>10 AM – 10 PM</dd></div>
          <div class="closed"><dt>Monday</dt><dd>Closed</dd></div>
        </dl>
        <div class="findus__ctas">
          <a href="https://maps.google.com/?q=3671+30th+St+San+Diego+CA+92104" target="_blank" rel="noopener noreferrer" class="btn-gold">Get Directions</a>
          <a href={`tel:${import.meta.env.PUBLIC_VENUE_PHONE}`} class="btn-text">{import.meta.env.PUBLIC_VENUE_PHONE}</a>
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>

