---
import { getSingleton, resolveContent } from '../../content/siteData';
// src/pages/the-space/index.astro
// Louisiana Purchase — The Space / Venue Lookbook Page
// Targets: "north park restaurant interior", "restaurant venue san diego", "louisiana purchase venue"

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import AlternatingRow from '../../components/ui/AlternatingRow.astro';
import StatBar from '../../components/ui/StatBar.astro';
import CTABand from '../../components/ui/CTABand.astro';
import FourColumnGrid from '../../components/ui/FourColumnGrid.astro';
import { IMAGES } from '../../assets/images';
import { Image } from 'astro:assets';
import { getOrderedCollection } from '../../content/siteData';

const spaceGalleryCards = (await getOrderedCollection('spaceGalleryCards')).map((card) => ({
  ...card,
  image: IMAGES[card.image as keyof typeof IMAGES],
}));
const pageContent = await getSingleton('theSpacePage', 'page');
const venue = await getSingleton('venueSettings', 'settings');
const VENUE_ADDRESS = venue.address;
const VENUE_MAPS_URL = venue.mapsUrl;
const DISPLAY_HOURS = Array.isArray(venue.displayHours) ? venue.displayHours : [];
const blocks = (Array.isArray(pageContent.blocks) ? pageContent.blocks : []).map((block: any) => resolveContent(block?.props ?? {}, IMAGES, import.meta.env));
const location = pageContent.location ?? {};
const locationBody = `\n${location.bodyPrefix ?? ''}${VENUE_ADDRESS.crossStreet.replace('&', '&amp;')}${location.bodyMiddle ?? ''}${VENUE_ADDRESS.neighborhood}${location.bodySuffix ?? ''}\n`;
---

<Layout {...blocks[0]}>

  <PageHero {...blocks[1]} />

  <StatBar {...blocks[2]} />

  <!-- ─── The Dining Room ──────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[3]} />

  <!-- ─── The Patio ────────────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[4]} />

  <!-- ─── Photo Gallery Grid ───────────────────────────────────────────── -->
  <section aria-labelledby="gallery-heading" class="bg-obsidian py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[5]} />

      <FourColumnGrid
        cols={4}
        dark={true}
        divided={true}
        cards={spaceGalleryCards}
      />

    </div>
  </section>

  <!-- ─── Private Events Callout ───────────────────────────────────────── -->
  <AlternatingRow {...blocks[6]} />

  <!-- ─── Location ─────────────────────────────────────────────────────── -->
  <section aria-labelledby="location-heading" class="bg-velvet py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

        <div>
          <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold mb-3" set:text={pageContent.location.eyebrow}></p>
          <h2 id="location-heading" class="font-serif font-light text-parchment tracking-[-0.02em] leading-[1.05] mb-5" style="font-size: clamp(2rem, 4vw, 3rem);">
            {VENUE_ADDRESS.street}<br /><span class="italic text-gold">{VENUE_ADDRESS.neighborhood}, {VENUE_ADDRESS.city}</span>
          </h2>
          <p class="font-sans font-light text-smoke leading-relaxed text-[0.9375rem] mb-8 max-w-[44ch]" set:html={locationBody}></p>

          <dl class="flex flex-col gap-4 mb-8 pt-6 border-t border-gold/15">
            {[
              { label: pageContent.location.addressLabel, value: `${VENUE_ADDRESS.street}, ${VENUE_ADDRESS.neighborhood}, ${VENUE_ADDRESS.city}, ${VENUE_ADDRESS.state} ${VENUE_ADDRESS.zip}` },
              ...DISPLAY_HOURS,
            ].map((item: { label: string; value: string }) => (
              <div class="flex justify-between gap-8">
                <dt class="font-sans text-[0.5625rem] font-medium tracking-[0.20em] uppercase text-gold/70 pt-0.5 whitespace-nowrap">{item.label}</dt>
                <dd class="font-sans text-sm text-parchment text-right whitespace-nowrap">{item.value}</dd>
              </div>
            ))}
          </dl>

          <div class="flex flex-wrap gap-4">
            <a href={VENUE_MAPS_URL} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-[280ms]" set:text={`\n${pageContent.location.directionsLabel}\n`}></a>
            <a href={import.meta.env.PUBLIC_RESERVATIONS_URL} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 border border-gold/40 text-gold hover:border-gold hover:bg-gold/5 transition-all duration-[280ms]" set:text={`\n${pageContent.location.reservationsLabel}\n`}></a>
          </div>
        </div>

        <div class="overflow-hidden aspect-[4/3]">
          <Image
            src={IMAGES[pageContent.location.image as keyof typeof IMAGES]}
            alt={pageContent.location.imageAlt}
            class="w-full h-full object-cover object-center"
            loading="lazy"
            decoding="async"
            format="webp"
            widths={[480, 800, 1200, 1600]}
            sizes="(min-width: 1024px) 50vw, 100vw"
          />
        </div>

      </div>
    </div>
  </section>

  <CTABand {...blocks[7]} />

</Layout>
