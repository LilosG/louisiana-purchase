---
// src/pages/private-events/index.astro
// Louisiana Purchase — Private Events Landing Page
// AEO-structured for high-intent unbranded queries.

import Layout from '../../layouts/Layout.astro';
import { PRIVATE_EVENT_SLUGS } from '../../data/private-events';
---

<Layout
  title="Private Events & Venue Buyouts | Louisiana Purchase North Park San Diego"
  description="Host an unforgettable private event at Louisiana Purchase in North Park, San Diego. Corporate dinners, birthday celebrations, jazz brunch buyouts, and full venue rental for up to 80 guests."
  canonical="/private-events"
  breadcrumbs={[
    { name: 'Home', url: '/', position: 1 },
    { name: 'Private Events', url: '/private-events', position: 2 },
  ]}
>
  <!-- ─── Hero ──────────────────────────────────────────────────────────── -->
  <section
    aria-labelledby="pe-headline"
    class="relative pt-hero pb-16 md:pb-24 bg-obsidian overflow-hidden"
  >
    <div aria-hidden="true" class="absolute inset-0 bg-velvet-gradient opacity-70"></div>
    <div class="relative z-raised max-w-layout mx-auto px-gutter">
      <p class="eyebrow mb-4">Venues &amp; Experiences</p>
      <h1
        id="pe-headline"
        class="font-display text-5xl md:text-7xl font-light text-parchment tracking-tighter mb-6 animate-fade-up"
      >
        Private Events<br />
        <span class="text-gradient-gold italic">Worth Remembering</span>
      </h1>
      <p class="font-sans text-base text-smoke-light max-w-prose-narrow mb-10 animate-fade-in">
        Louisiana Purchase offers an unparalleled private dining and event experience in North Park, San Diego.
        From intimate corporate dinners to full venue buyouts — we provide the space, the cuisine,
        and the atmosphere that transforms an occasion into a memory.
      </p>
      <a
        href={import.meta.env.PUBLIC_PRIVATE_EVENTS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="eyebrow inline-flex px-8 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-base ease-luxury rounded-sm animate-fade-up"
        aria-label="Submit a private event inquiry for Louisiana Purchase"
      >
        Submit an Inquiry
      </a>
    </div>
  </section>

  <!-- ─── AEO: Venue Facts ──────────────────────────────────────────────── -->
  <section
    aria-labelledby="venue-facts-heading"
    class="py-section bg-obsidian-800 border-y border-gold/10"
  >
    <div class="max-w-layout mx-auto px-gutter">
      <h2 id="venue-facts-heading" class="sr-only">Venue Specifications</h2>

      <!-- Key-value block — optimized for AI parser ingestion -->
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0 md:divide-x divide-gold/10">
        <div class="md:px-8 first:pl-0 last:pr-0 animate-on-scroll">
          <dt class="eyebrow mb-2">Max Capacity</dt>
          <dd class="font-serif text-3xl font-light text-gold">80</dd>
          <dd class="font-sans text-sm text-smoke-light mt-1">Guests (full venue)</dd>
        </div>
        <div class="md:px-8 animate-on-scroll" style="animation-delay: 80ms">
          <dt class="eyebrow mb-2">Private Room</dt>
          <dd class="font-serif text-3xl font-light text-gold">40</dd>
          <dd class="font-sans text-sm text-smoke-light mt-1">Guests (seated dining)</dd>
        </div>
        <div class="md:px-8 animate-on-scroll" style="animation-delay: 160ms">
          <dt class="eyebrow mb-2">Patio</dt>
          <dd class="font-serif text-3xl font-light text-gold">50</dd>
          <dd class="font-sans text-sm text-smoke-light mt-1">Guests (reception)</dd>
        </div>
        <div class="md:px-8 animate-on-scroll" style="animation-delay: 240ms">
          <dt class="eyebrow mb-2">Location</dt>
          <dd class="font-serif text-xl font-light text-gold">North Park</dd>
          <dd class="font-sans text-sm text-smoke-light mt-1">San Diego, CA 92104</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ─── Event Type Directory ─────────────────────────────────────────── -->
  <section
    aria-labelledby="event-types-heading"
    class="py-section bg-obsidian"
  >
    <div class="max-w-layout mx-auto px-gutter">
      <header class="mb-12 animate-on-scroll">
        <p class="eyebrow mb-3">Browse by Event Type</p>
        <h2
          id="event-types-heading"
          class="font-serif text-4xl font-light text-parchment tracking-tighter"
        >
          Every Occasion, Elevated
        </h2>
      </header>

      <ul role="list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-gold/10">
        {PRIVATE_EVENT_SLUGS.map((event, i) => (
          <li class="bg-obsidian-800 animate-on-scroll" style={`animation-delay: ${i * 60}ms`}>
            <a
              href={`/private-events/${event.slug}`}
              class="group block p-8 h-full flex flex-col gap-4"
              aria-label={`Learn more about ${event.title} at Louisiana Purchase`}
            >
              <p class="eyebrow text-gold">{event.eventType}</p>
              <h3 class="font-serif text-xl font-light text-parchment group-hover:text-gold transition-colors duration-base ease-luxury">
                {event.title}
              </h3>
              <p class="font-sans text-sm text-smoke-light leading-relaxed">
                {event.description}
              </p>
              <dl class="mt-auto pt-4 border-t border-gold/10 flex gap-8">
                <div>
                  <dt class="font-mono text-2xs text-smoke tracking-wider mb-1">Capacity</dt>
                  <dd class="font-sans text-sm text-parchment/80">{event.capacity}</dd>
                </div>
                <div>
                  <dt class="font-mono text-2xs text-smoke tracking-wider mb-1">Pricing</dt>
                  <dd class="font-sans text-sm text-parchment/80">{event.priceGuide}</dd>
                </div>
              </dl>
              <span class="eyebrow text-gold group-hover:translate-x-1 transition-transform duration-base ease-luxury inline-block mt-2">
                Learn More →
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ─── Inquiry CTA ───────────────────────────────────────────────────── -->
  <section
    aria-label="Private event inquiry"
    class="py-section bg-velvet border-t border-gold/10 text-center"
  >
    <div class="max-w-layout mx-auto px-gutter animate-on-scroll">
      <p class="eyebrow mb-6">Get Started</p>
      <h2 class="font-serif text-3xl md:text-4xl font-light text-parchment tracking-tighter mb-4">
        Ready to Plan Your Event?
      </h2>
      <p class="font-sans text-sm text-smoke-light max-w-prose-narrow mx-auto mb-8">
        Our events team will work with you to design a custom experience — from menu curation
        to cocktail pairings and room configuration.
      </p>
      <a
        href={import.meta.env.PUBLIC_PRIVATE_EVENTS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="eyebrow inline-flex px-10 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-base ease-luxury rounded-sm"
        aria-label="Submit a private event inquiry at Louisiana Purchase"
      >
        Submit an Inquiry
      </a>
    </div>
  </section>

</Layout>
