---
// src/pages/private-events/index.astro
// Louisiana Purchase — Private Events Hub Page
// Full rebuild using shared components and Tailwind v4 classes.

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import AlternatingRow from '../../components/ui/AlternatingRow.astro';
import StatBar from '../../components/ui/StatBar.astro';
import CTABand from '../../components/ui/CTABand.astro';
import FourColumnGrid from '../../components/ui/FourColumnGrid.astro';
import ChecklistItems from '../../components/ui/ChecklistItems.astro';
import { PRIVATE_EVENT_SLUGS } from '../../data/private-events';
import { VENUE_ADDRESS, EVENT_CAPACITY } from '../../data/venue';
import { IMAGES } from '../../assets/images';

const PROCESS_STEPS = [
  { step: '01', title: 'Submit an Inquiry',     body: 'Tell us your event date, headcount, and vision. Our events team responds within 24 hours.' },
  { step: '02', title: 'Custom Proposal',       body: 'We\'ll put together a tailored proposal — menu options, room configuration, pricing, and cocktail packages.' },
  { step: '03', title: 'Confirm & Personalize', body: 'Finalize the agreement and refine every detail — from signature cocktail selections to dietary accommodations.' },
  { step: '04', title: 'Your Event',            body: 'Show up and experience it. Our team handles everything from setup to service so you can be present for every moment.' },
];

const FAQ_ITEMS = [
  { q: 'What is the minimum guest count for a private event?',  a: 'Minimums vary by space and date. The private dining room requires a food and beverage minimum for groups of 15 or more. Full venue buyouts have their own minimum. Contact our events team for specifics.' },
  { q: 'Can I customize the menu for my event?',                a: 'Yes. Chef Quinnton Austin and our culinary team offer fully bespoke menu curation for private events — from passed cocktail-hour bites to multi-course Creole dinner experiences.' },
  { q: 'Does Louisiana Purchase offer cocktail pairings?',      a: 'Our bar program specializes in custom cocktail pairings and curated open bar packages. All signature cocktails including the Praline Old Fashioned and Voo Doo Carré are available for event menus.' },
  { q: 'How far in advance should I book?',                     a: 'We recommend inquiring at least 3–4 weeks in advance for weekday events and 6–8 weeks for weekend dates. Popular dates book quickly, especially Friday and Saturday evenings.' },
  { q: 'Is parking available near Louisiana Purchase?',         a: `Street parking is available on University Ave and surrounding streets in North Park. Several nearby parking lots are within a short walk of the venue at ${VENUE_ADDRESS.street}.` },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
---

<Layout
  title="Private Events & Venue Buyouts in North Park San Diego | Louisiana Purchase"
  description="Host an unforgettable private event at Louisiana Purchase in North Park, San Diego. Corporate dinners, birthday celebrations, brunch buyouts, and full venue rental for up to 80 guests."
  canonical="/private-events"
  schema={faqSchema}
  breadcrumbs={[
    { name: 'Home',           url: '/',               position: 1 },
    { name: 'Private Events', url: '/private-events', position: 2 },
  ]}
>

  <PageHero
    eyebrow="Group Bookings & Venue Buyouts"
    title="Private Events"
    titleItalic="Worth Remembering"
    subtitle="Louisiana Purchase offers an unparalleled private dining and event experience in North Park, San Diego. From intimate corporate dinners to full venue buyouts — the space, the cuisine, and the atmosphere your guests will talk about."
    image={IMAGES['louisiana-purchase-date-night-north-park-website']}
    imageAlt="Private events at Louisiana Purchase North Park San Diego"
    ctas={[
      { label: 'Submit an Inquiry', href: import.meta.env.PUBLIC_PRIVATE_EVENTS_URL, external: true, variant: 'gold' },
      { label: 'View Event Types',  href: '#event-types', variant: 'outline' },
    ]}
    headlineId="pe-headline"
  />

  <StatBar
    stats={[
      { value: String(EVENT_CAPACITY.fullVenue),   label: 'Max Capacity' },
      { value: String(EVENT_CAPACITY.privateRoom), label: 'Private Room' },
      { value: String(EVENT_CAPACITY.patio),       label: 'Patio Reception' },
      { value: 'Custom',    label: 'Menus Available' },
    ]}
    dark={true}
  />

  <!-- ─── Why Louisiana Purchase ───────────────────────────────────────── -->
  <AlternatingRow
    image={IMAGES['louisiana-purchase-private-dining-san-diego-website']}
    imageAlt="Private dining room at Louisiana Purchase North Park San Diego"
    eyebrow="The Venue"
    title="A Private Event Venue"
    titleItalic="Like No Other in North Park"
    body={[
      "Louisiana Purchase isn't a banquet hall. It's a genuine hospitality experience — the geometric timber ceiling, the candlelit bar, the lush open patio. Every element of the space was designed for atmosphere, not capacity.",
      "Our events team works with you to design a completely custom experience. Menu curation, cocktail pairings, room configuration, AV — everything handled with the same precision as our dinner service.",
    ]}
    facts={[
      { label: 'Full Venue',    value: `Up to ${EVENT_CAPACITY.fullVenue} Guests` },
      { label: 'Private Room',  value: `Up to ${EVENT_CAPACITY.privateRoom} Guests` },
      { label: 'Patio',         value: `Up to ${EVENT_CAPACITY.patio} Guests` },
      { label: 'Location',      value: 'North Park, SD' },
    ]}
    ctas={[
      { label: 'Submit an Inquiry', href: import.meta.env.PUBLIC_PRIVATE_EVENTS_URL, external: true, variant: 'gold' },
    ]}
    dark={true}
  />

  <!-- ─── Event Types ──────────────────────────────────────────────────── -->
  <section id="event-types" aria-labelledby="event-types-heading" class="bg-velvet py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader
        eyebrow="Browse by Event Type"
        title="Every Occasion,"
        titleItalic="Elevated"
        subtitle="From intimate corporate dinners to full venue buyouts — Louisiana Purchase handles events of every scale with the same level of care."
        id="event-types-heading"
      />

      <ul role="list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-gold/10">
        {PRIVATE_EVENT_SLUGS.map((event) => (
          <li class="bg-velvet-800 reveal">
            <a
              href={`/private-events/${event.slug}`}
              class="group flex flex-col gap-3 p-7 h-full hover:bg-velvet-700 transition-colors duration-[280ms]"
              aria-label={`Learn more about ${event.title} at Louisiana Purchase`}
            >
              <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold">
                {event.eventType}
              </p>
              <h3 class="font-serif font-light text-parchment group-hover:text-gold transition-colors duration-[280ms]"
                  style="font-size: clamp(1.125rem, 1.75vw, 1.25rem);">
                {event.title}
              </h3>
              <p class="font-sans font-light text-smoke leading-relaxed text-sm flex-1">
                {event.description}
              </p>
              <dl class="flex gap-8 pt-4 border-t border-gold/10 mt-auto">
                <div>
                  <dt class="font-sans text-[0.5rem] font-medium tracking-[0.24em] uppercase text-smoke mb-1">Capacity</dt>
                  <dd class="font-sans text-sm text-parchment/80">{event.capacity}</dd>
                </div>
                <div>
                  <dt class="font-sans text-[0.5rem] font-medium tracking-[0.24em] uppercase text-smoke mb-1">Pricing</dt>
                  <dd class="font-sans text-sm text-parchment/80">{event.priceGuide}</dd>
                </div>
              </dl>
              <span class="font-sans text-[0.5625rem] font-medium tracking-[0.16em] uppercase text-gold group-hover:translate-x-1 transition-transform duration-[280ms] inline-block mt-1">
                Learn More →
              </span>
            </a>
          </li>
        ))}
      </ul>

    </div>
  </section>

  <!-- ─── The Process ──────────────────────────────────────────────────── -->
  <section aria-labelledby="process-heading" class="bg-obsidian py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader
        eyebrow="How It Works"
        title="From First Inquiry"
        titleItalic="to Your Event"
        subtitle="Our events team handles every detail from first contact to last call."
        id="process-heading"
      />

      <ChecklistItems items={PROCESS_STEPS} numbered={true} cols={4} dark={true} />

    </div>
  </section>

  <!-- ─── The Space ────────────────────────────────────────────────────── -->
  <AlternatingRow
    image={IMAGES['louisiana-purchase-group-dining-san-diego-website']}
    imageAlt="Group dining at Louisiana Purchase North Park San Diego"
    eyebrow="The Space"
    title="Three Distinct"
    titleItalic="Event Spaces"
    body={[
      "Louisiana Purchase offers three configurable spaces — the intimate private dining room for seated dinners up to 40, the full restaurant buyout for groups up to 80, and the lush open patio for cocktail receptions and standing events.",
      "Each space can be configured independently or combined for larger events. Our team will recommend the best configuration for your headcount and event style.",
    ]}
    facts={[
      { label: 'Private Room',      value: `Up to ${EVENT_CAPACITY.privateRoom} seated` },
      { label: 'Full Venue',        value: `Up to ${EVENT_CAPACITY.fullVenue} guests` },
      { label: 'Patio Reception',   value: `Up to ${EVENT_CAPACITY.patio} standing` },
      { label: 'AV & Setup',        value: 'Available' },
    ]}
    ctas={[
      { label: 'Inquire About Your Event', href: import.meta.env.PUBLIC_PRIVATE_EVENTS_URL, external: true, variant: 'gold' },
    ]}
    reverse={true}
    dark={false}
  />

  <!-- ─── FAQ ───────────────────────────────────────────────────────────── -->
  <section aria-labelledby="pe-faq-heading" class="bg-obsidian py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader
        eyebrow="Common Questions"
        title="Private Events FAQ"
        subtitle="Everything you need to know about hosting a private event at Louisiana Purchase in North Park, San Diego."
        id="pe-faq-heading"
      />

      <dl class="divide-y divide-gold/10 max-w-[80ch] mx-auto">
        {FAQ_ITEMS.map((faq) => (
          <div class="py-5 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-12 reveal">
            <dt class="font-serif font-light text-parchment text-base">{faq.q}</dt>
            <dd class="font-sans font-light text-smoke leading-relaxed text-sm">{faq.a}</dd>
          </div>
        ))}
      </dl>

    </div>
  </section>

  <CTABand
    eyebrow="Let's Get Started"
    title="Ready to Plan Your Event?"
    subtitle="Our events team will respond within 24 hours with availability and a custom proposal."
    image={IMAGES['louisiana-purchase-north-park-restaurant-and-bar-website']}
    ctas={[
      { label: 'Submit an Inquiry', href: import.meta.env.PUBLIC_PRIVATE_EVENTS_URL, external: true, variant: 'gold' },
      { label: 'View Event Types',  href: '#event-types', variant: 'outline' },
    ]}
  />

</Layout>
