---
import { getSingleton, resolveContent, buildEnv } from '../../content/siteData';
// src/pages/private-events/index.astro
// Louisiana Purchase — Private Events Hub Page
// Full rebuild using shared components and Tailwind v4 classes.

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import AlternatingRow from '../../components/ui/AlternatingRow.astro';
import StatBar from '../../components/ui/StatBar.astro';
import CTABand from '../../components/ui/CTABand.astro';
import ChecklistItems from '../../components/ui/ChecklistItems.astro';
import ToastEventForm from '../../components/ui/ToastEventForm.astro';
import { IMAGES } from '../../assets/images';
import { getOrderedCollection } from '../../content/siteData';

const PRIVATE_EVENT_SLUGS = await getOrderedCollection('privateEventTypes');
const PROCESS_STEPS = await getOrderedCollection('privateEventsProcessSteps');
const FAQ_ITEMS = await getOrderedCollection('privateEventsFaqs');

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
const pageContent = await getSingleton('privateEventsIndexPage', 'page');
const venue = await getSingleton('venueSettings', 'settings');
const blocks = (Array.isArray(pageContent.blocks) ? pageContent.blocks : []).map((block: any) => resolveContent(block?.props ?? {}, IMAGES, buildEnv(venue, import.meta.env)));
---

<Layout
  title={pageContent.seo.title}
  description={pageContent.seo.description}
  canonical={pageContent.seo.canonical}
  schema={faqSchema}
  breadcrumbs={pageContent.seo.breadcrumbs}
>

  <PageHero {...blocks[0]} />

  <StatBar {...blocks[1]} />

  <!-- ─── Why Louisiana Purchase ───────────────────────────────────────── -->
  <AlternatingRow {...blocks[2]} />

  <!-- ─── Event Types ──────────────────────────────────────────────────── -->
  <section id="event-types" aria-labelledby="event-types-heading" class="bg-velvet py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[3]} />

      <ul role="list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-gold/10">
        {PRIVATE_EVENT_SLUGS.map((event) => (
          <li class="bg-velvet-800 reveal">
            <a
              href={`/private-events/${event.slug}`}
              class="group flex flex-col gap-3 p-7 h-full hover:bg-velvet-700 transition-colors duration-[280ms]"
              aria-label={`${pageContent.eventCardLabels.ariaLabelPrefix} ${event.title} ${pageContent.eventCardLabels.ariaLabelSuffix}`}
            >
              <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold">
                {event.eventType}
              </p>
              <h3 class="font-serif font-light text-parchment group-hover:text-gold transition-colors duration-[280ms]"
                  style="font-size: clamp(1.125rem, 1.75vw, 1.25rem);">
                {event.title}
              </h3>
              <p class="font-sans font-light text-smoke leading-relaxed text-sm flex-1">
                {event.description}
              </p>
              <dl class="flex gap-8 pt-4 border-t border-gold/10 mt-auto">
                <div>
                  <dt class="font-sans text-[0.5rem] font-medium tracking-[0.24em] uppercase text-smoke mb-1" set:text={pageContent.eventCardLabels.capacity}></dt>
                  <dd class="font-sans text-sm text-parchment/80">{event.capacity}</dd>
                </div>
                <div>
                  <dt class="font-sans text-[0.5rem] font-medium tracking-[0.24em] uppercase text-smoke mb-1" set:text={pageContent.eventCardLabels.pricing}></dt>
                  <dd class="font-sans text-sm text-parchment/80">{event.priceGuide}</dd>
                </div>
              </dl>
              <span class="font-sans text-[0.5625rem] font-medium tracking-[0.16em] uppercase text-gold group-hover:translate-x-1 transition-transform duration-[280ms] inline-block mt-1" set:text={`\n${pageContent.eventCardLabels.learnMore}\n`}></span>
            </a>
          </li>
        ))}
      </ul>

    </div>
  </section>

  <!-- ─── The Process ──────────────────────────────────────────────────── -->
  <section aria-labelledby="process-heading" class="bg-obsidian py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[4]} />

      <ChecklistItems items={PROCESS_STEPS} numbered={true} cols={4} dark={true} />

    </div>
  </section>

  <!-- ─── The Space ────────────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[5]} />

  <!-- ─── FAQ ───────────────────────────────────────────────────────────── -->
  <section aria-labelledby="pe-faq-heading" class="bg-obsidian py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[6]} />

      <dl class="divide-y divide-gold/10 max-w-[80ch] mx-auto">
        {FAQ_ITEMS.map((faq) => (
          <div class="py-5 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-12 reveal">
            <dt class="font-serif font-light text-parchment text-base">{faq.q}</dt>
            <dd class="font-sans font-light text-smoke leading-relaxed text-sm">{faq.a}</dd>
          </div>
        ))}
      </dl>

    </div>
  </section>

  <CTABand {...blocks[7]} />

  <ToastEventForm {...blocks[8]} />

</Layout>
