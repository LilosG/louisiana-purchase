---
// src/pages/private-events/[slug].astro
// Louisiana Purchase — Programmatic Private Event SEO Routes
//
// Generates one static page per entry in PRIVATE_EVENT_SLUGS.
// Each page targets a specific high-intent unbranded keyword combination.
// getStaticPaths() drives the full static build — no server-side rendering required.

import Layout from '../../layouts/Layout.astro';
import { PRIVATE_EVENT_SLUGS } from '../../data/private-events';
import type { PrivateEventSlug } from '../../types/seo';

export async function getStaticPaths() {
  return PRIVATE_EVENT_SLUGS.map((event: PrivateEventSlug) => ({
    params: { slug: event.slug },
    props:  { event },
  }));
}

interface Props {
  event: PrivateEventSlug;
}

const { event } = Astro.props;

// Build a page-specific EventVenue JSON-LD override to layer on top of the
// base Restaurant schema injected by <LocalSEO/>.
const eventVenueSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type':    'EventVenue',
  name:       `Louisiana Purchase — ${event.title}`,
  description: event.description,
  url:        `${import.meta.env.PUBLIC_SITE_URL}/private-events/${event.slug}`,
  maximumAttendeeCapacity: event.capacity,
  address: {
    '@type':          'PostalAddress',
    streetAddress:    '3671 30th St',
    addressLocality:  'San Diego',
    addressRegion:    'CA',
    postalCode:       '92104',
    addressCountry:   'US',
  },
};
---

<Layout
  title={event.metaTitle}
  description={event.description}
  canonical={`/private-events/${event.slug}`}
  schema={eventVenueSchema}
  breadcrumbs={[
    { name: 'Home',           url: '/',              position: 1 },
    { name: 'Private Events', url: '/private-events', position: 2 },
    { name: event.title,      url: `/private-events/${event.slug}`, position: 3 },
  ]}
>
  <!-- ─── Hero ──────────────────────────────────────────────────────────── -->
  <section
    aria-labelledby="slug-headline"
    class="relative pt-hero pb-16 md:pb-24 bg-obsidian overflow-hidden"
  >
    <div aria-hidden="true" class="absolute inset-0 bg-velvet-gradient opacity-70"></div>

    <div class="relative z-raised max-w-layout mx-auto px-gutter">
      <!-- Breadcrumb — semantic nav, not decorative -->
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 font-mono text-xs text-smoke-light" role="list">
          <li><a href="/" class="hover:text-gold transition-colors duration-base ease-luxury">Home</a></li>
          <li aria-hidden="true" class="text-gold/30">/</li>
          <li><a href="/private-events" class="hover:text-gold transition-colors duration-base ease-luxury">Private Events</a></li>
          <li aria-hidden="true" class="text-gold/30">/</li>
          <li class="text-parchment/50" aria-current="page">{event.title}</li>
        </ol>
      </nav>

      <p class="eyebrow mb-4 text-gold">{event.eventType}</p>
      <h1
        id="slug-headline"
        class="font-display text-4xl md:text-6xl font-light text-parchment tracking-tighter mb-6 animate-fade-up"
      >
        {event.title}
      </h1>
      <p class="font-sans text-base text-smoke-light max-w-prose-narrow mb-10 animate-fade-in">
        {event.description}
      </p>
      <a
        href={import.meta.env.PUBLIC_PRIVATE_EVENTS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="eyebrow inline-flex px-8 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-base ease-luxury rounded-sm animate-fade-up"
        aria-label={`Inquire about ${event.title} at Louisiana Purchase`}
      >
        Request a Proposal
      </a>
    </div>
  </section>

  <!-- ─── AEO: Event Specifications ────────────────────────────────────── -->
  <section
    aria-labelledby="event-specs-heading"
    class="py-section bg-obsidian-800 border-y border-gold/10"
  >
    <div class="max-w-layout mx-auto px-gutter">
      <h2 id="event-specs-heading" class="eyebrow mb-8">Event Details</h2>

      <!-- Structured key-value table — high AEO parse priority -->
      <dl class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        <div class="animate-on-scroll">
          <dt class="eyebrow mb-2">Event Type</dt>
          <dd class="font-serif text-2xl font-light text-parchment">{event.eventType}</dd>
        </div>
        <div class="animate-on-scroll" style="animation-delay: 80ms">
          <dt class="eyebrow mb-2">Capacity</dt>
          <dd class="font-serif text-2xl font-light text-gold">{event.capacity}</dd>
        </div>
        <div class="animate-on-scroll" style="animation-delay: 160ms">
          <dt class="eyebrow mb-2">Venue</dt>
          <dd class="font-serif text-2xl font-light text-parchment">Louisiana Purchase</dd>
          <dd class="font-sans text-sm text-smoke-light mt-1">3671 30th St, North Park, San Diego</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ─── AEO: FAQ Block ────────────────────────────────────────────────── -->
  <!--
    Structured QA format targeted at AI search engine featured snippet capture.
    Answers queries like "how to book private dining in north park"
  -->
  <section
    aria-labelledby="faq-heading"
    class="py-section bg-obsidian"
  >
    <div class="max-w-layout mx-auto px-gutter">
      <h2
        id="faq-heading"
        class="font-serif text-3xl font-light text-parchment tracking-tighter mb-12 animate-on-scroll"
      >
        Frequently Asked Questions
      </h2>

      <dl class="divide-y divide-gold/10 animate-on-scroll">
        {[
          {
            q: `How do I book a ${event.eventType.toLowerCase()} at Louisiana Purchase?`,
            a: `Submit an inquiry through our private events portal. Our events team will respond within 24 hours to discuss availability, menu options, and pricing for your ${event.eventType.toLowerCase()} in North Park, San Diego.`,
          },
          {
            q: `What is the minimum guest count for a ${event.eventType.toLowerCase()}?`,
            a: `We accommodate ${event.capacity}. Minimums vary by space configuration and date. Contact our events team for a custom quote.`,
          },
          {
            q: 'Can I customize the menu for my event?',
            a: 'Yes. Chef Quinnton Austin and our culinary team offer fully bespoke menu curation for private events — from passed cocktail-hour bites to multi-course Creole dinner experiences.',
          },
          {
            q: 'Does Louisiana Purchase offer in-house cocktail pairings?',
            a: 'Our bar program specializes in custom cocktail pairings and curated open bar packages. Signature cocktails including the Praline Old Fashioned and Voo Doo Carré are available for event menus.',
          },
        ].map((faq, i) => (
          <div class="py-8 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-16 animate-on-scroll" style={`animation-delay: ${i * 60}ms`}>
            <dt class="font-serif text-lg font-light text-parchment">{faq.q}</dt>
            <dd class="font-sans text-sm text-smoke-light leading-relaxed">{faq.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────────────────────── -->
  <section
    aria-label="Event inquiry call to action"
    class="py-section bg-velvet border-t border-gold/10 text-center"
  >
    <div class="max-w-layout mx-auto px-gutter animate-on-scroll">
      <h2 class="font-serif text-3xl font-light text-parchment tracking-tighter mb-4">
        Let's Build Your Experience
      </h2>
      <p class="font-sans text-sm text-smoke-light max-w-prose-narrow mx-auto mb-8">
        Our events team is ready to design a {event.eventType.toLowerCase()} that exceeds every expectation.
        Inquire today to check availability.
      </p>
      <a
        href={import.meta.env.PUBLIC_PRIVATE_EVENTS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="eyebrow inline-flex px-10 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-base ease-luxury rounded-sm"
        aria-label={`Request a proposal for ${event.title} at Louisiana Purchase`}
      >
        Request a Proposal
      </a>
    </div>
  </section>

</Layout>
