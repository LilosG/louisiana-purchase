---
// src/pages/private-events/[...slug].astro
// Louisiana Purchase — Programmatic Private Event SEO Routes
// Catch-all routing for all private event sub-pages.

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import AlternatingRow from '../../components/ui/AlternatingRow.astro';
import StatBar from '../../components/ui/StatBar.astro';
import CTABand from '../../components/ui/CTABand.astro';
import ChecklistItems from '../../components/ui/ChecklistItems.astro';
import ToastEventForm from '../../components/ui/ToastEventForm.astro';
import type { PrivateEventSlug } from '../../types/seo';
import { IMAGES } from '../../assets/images';
import { getOrderedCollection } from '../../content/siteData';
import { getSingleton } from '../../content/siteData';

export async function getStaticPaths() {
  const PRIVATE_EVENT_SLUGS = await getOrderedCollection('privateEventTypes');
  return PRIVATE_EVENT_SLUGS.map((event: PrivateEventSlug) => ({
    params: { slug: event.slug },
    props:  { event },
  }));
}

interface Props {
  event: PrivateEventSlug;
}

const { event } = Astro.props as Props;
const template = await getSingleton('privateEventsSlugTemplate', 'template');
const venue = await getSingleton('venueSettings', 'settings');
const CANONICAL_DOMAIN = venue.domain;
const VENUE_ADDRESS = venue.address;
const fill = (value: any): any => {
  if (typeof value === 'string') return value.replaceAll('{{eventTypeLower}}', event.eventType.toLowerCase()).replaceAll('{{eventType}}', event.eventType).replaceAll('{{capacity}}', event.capacity).replaceAll('{{title}}', event.title);
  if (Array.isArray(value)) return value.map(fill);
  if (value && typeof value === 'object') return Object.fromEntries(Object.entries(value).map(([key, item]) => [key, fill(item)]));
  return value;
};

const eventVenueSchema: Record<string, unknown> = {
  '@context':  'https://schema.org',
  '@type':     'EventVenue',
  name:        `${template.seo.schemaNamePrefix}${event.title}`,
  description: event.description,
  url:         `${import.meta.env.PUBLIC_SITE_URL || CANONICAL_DOMAIN}${template.seo.canonicalBase}${event.slug}`,
  address: {
    '@type':          'PostalAddress',
    streetAddress:    VENUE_ADDRESS.street,
    addressLocality:  VENUE_ADDRESS.city,
    addressRegion:    VENUE_ADDRESS.state,
    postalCode:       VENUE_ADDRESS.zip,
    addressCountry:   VENUE_ADDRESS.country,
  },
};

const FAQ_ITEMS = fill(template.faqs) as Array<{ q: string; a: string }>;

const INCLUDED_ITEMS = template.includedItems;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
---

<Layout
  title={event.metaTitle}
  description={event.description}
  canonical={`${template.seo.canonicalBase}${event.slug}`}
  schema={[eventVenueSchema, faqSchema]}
  breadcrumbs={[
    ...template.seo.breadcrumbs,
    { name: event.title,      url: `/private-events/${event.slug}`, position: 3 },
  ]}
>

  <PageHero
    eyebrow={event.eventType}
    title={event.title}
    subtitle={event.description}
    image={IMAGES[template.hero.image as keyof typeof IMAGES]}
    imageAlt={fill(template.hero.imageAlt)}
    ctas={template.heroCtas}
    headlineId={template.hero.headlineId}
  />

  <StatBar
    stats={fill(template.stats)}
    dark={true}
  />

  <AlternatingRow
    image={IMAGES[template.experienceImage.image as keyof typeof IMAGES]}
    imageAlt={fill(template.experienceImage.imageAlt)}
    {...fill(template.experience)}
    dark={true}
  />

  <!-- ─── What's Included ──────────────────────────────────────────────── -->
  <section aria-labelledby="included-heading" class="bg-velvet py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader
        {...fill(template.includedHeader)}
      />

      <ChecklistItems items={INCLUDED_ITEMS} cols={3} dark={false} />

    </div>
  </section>

  <!-- ─── FAQ ───────────────────────────────────────────────────────────── -->
  <section aria-labelledby="slug-faq-heading" class="bg-obsidian py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader
        {...fill(template.faqHeader)}
      />

      <dl class="divide-y divide-gold/10 max-w-[80ch] mx-auto">
        {FAQ_ITEMS.map((faq) => (
          <div class="py-5 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-12 reveal">
            <dt class="font-serif font-light text-parchment text-base">{faq.q}</dt>
            <dd class="font-sans font-light text-smoke leading-relaxed text-sm">{faq.a}</dd>
          </div>
        ))}
      </dl>

    </div>
  </section>

  <CTABand
    {...fill(template.cta)}
    image={IMAGES[template.cta.image as keyof typeof IMAGES]}
  />

  <ToastEventForm
    {...fill(template.form)}
  />

</Layout>
