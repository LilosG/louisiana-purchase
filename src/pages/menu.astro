---
// src/pages/menu.astro
// Louisiana Purchase — Menu Page
// Programmatically parses src/data/menu.json — NO inline menu content permitted.
// Data-driven render with full TypeScript typing.

import Layout from '../layouts/Layout.astro';
import type { MenuData, MenuSection, MenuCategory, MenuItem } from '../types/menu';
import menuData from '../data/menu.json';

// Runtime type assertion — enforce shape at module boundary
const menu = menuData as MenuData;
---

<Layout
  title="Menu — Louisiana Purchase | Creole Dining & Craft Cocktails in North Park"
  description="Explore Louisiana Purchase's full menu — fire-charred oysters, Praline Old Fashioneds, Voo Doo Carré cocktails, and Chef Quinnton Austin's elevated Creole kitchen in North Park, San Diego."
  canonical="/menu"
  breadcrumbs={[
    { name: 'Home', url: '/', position: 1 },
    { name: 'Menu', url: '/menu', position: 2 },
  ]}
>
  <!-- ─── Menu Hero ─────────────────────────────────────────────────────── -->
  <section
    aria-labelledby="menu-headline"
    class="relative pt-hero pb-16 md:pb-24 bg-obsidian overflow-hidden"
  >
    <div aria-hidden="true" class="absolute inset-0 bg-velvet-gradient opacity-60"></div>
    <div class="relative z-raised max-w-layout mx-auto px-gutter text-center">
      <p class="eyebrow mb-4">The Kitchen &amp; Bar</p>
      <h1
        id="menu-headline"
        class="font-display text-5xl md:text-7xl font-light text-parchment tracking-tighter mb-4 animate-fade-up"
      >
        Our Menu
      </h1>
      <p class="font-serif text-lg italic text-parchment/60 animate-fade-in">
        All items subject to seasonal availability. Prices do not include tax or gratuity.
      </p>
    </div>
  </section>

  <!-- ─── Menu Navigation (Filter Tabs) ────────────────────────────────── -->
  <nav
    aria-label="Menu section navigation"
    class="sticky top-nav z-raised bg-obsidian-800 border-b border-gold/10"
  >
    <div class="max-w-layout mx-auto px-gutter">
      <ul role="list" class="flex gap-0 overflow-x-auto scrollbar-hide">
        {menu.sections.map((section: MenuSection) => (
          <li>
            <a
              href={`#${section.id}`}
              class="eyebrow inline-flex px-6 py-5 text-smoke-light border-b-2 border-transparent
                     hover:text-gold hover:border-gold
                     transition-all duration-base ease-luxury whitespace-nowrap"
            >
              {section.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- ─── Menu Sections ─────────────────────────────────────────────────── -->
  <div class="bg-obsidian py-12 md:py-20">
    {menu.sections.map((section: MenuSection) => (
      <section
        id={section.id}
        aria-labelledby={`${section.id}-heading`}
        class="max-w-layout mx-auto px-gutter mb-20"
      >
        <!-- Section Header -->
        <header class="mb-12 pb-8 border-b border-gold/15">
          <h2
            id={`${section.id}-heading`}
            class="font-serif text-4xl md:text-5xl font-light text-parchment tracking-tighter mb-3"
          >
            {section.title}
          </h2>
          <p class="font-sans text-sm text-smoke-light max-w-prose-narrow">
            {section.subtitle}
          </p>
        </header>

        <!-- Categories -->
        {section.categories.map((category: MenuCategory) => (
          <div class="mb-14">
            <h3
              class="eyebrow mb-6 pb-3 border-b border-gold/10"
            >
              {category.label}
            </h3>

            {/* Category description — AEO: provides context for AI parsers */}
            {category.description && (
              <p class="font-sans text-sm text-smoke-dark mb-8 italic">
                {category.description}
              </p>
            )}

            <!-- Menu Items Grid -->
            <ul role="list" class="grid grid-cols-1 md:grid-cols-2 gap-px bg-gold/10">
              {category.items
                .filter((item: MenuItem) => item.available)
                .map((item: MenuItem) => (
                  <li class="bg-obsidian-800 p-8 flex flex-col gap-3 group animate-on-scroll">

                    <!-- Item Header -->
                    <header class="flex justify-between items-start gap-4">
                      <h4 class="font-serif text-xl font-light text-parchment group-hover:text-gold transition-colors duration-base ease-luxury">
                        {item.name}
                        {item.featured && (
                          <span class="ml-2 font-mono text-2xs text-gold/70 tracking-widest align-middle">
                            ✦
                          </span>
                        )}
                      </h4>
                      <span class="font-mono text-sm text-gold shrink-0 mt-0.5">
                        {item.priceDisplay}
                      </span>
                    </header>

                    <!-- Item Description -->
                    <p class="font-sans text-sm text-smoke-light leading-relaxed">
                      {item.description}
                    </p>

                    <!-- Tags & Dietary -->
                    {(item.tags.length > 0 || item.dietary.length > 0) && (
                      <footer class="flex flex-wrap gap-2 mt-1">
                        {item.tags.includes('signature') && (
                          <span class="font-mono text-2xs text-crimson-400 tracking-wider">
                            Signature
                          </span>
                        )}
                        {item.tags.includes('chef-selection') && (
                          <span class="font-mono text-2xs text-gold/60 tracking-wider">
                            Chef's Selection
                          </span>
                        )}
                        {item.dietary.includes('gluten-free') && (
                          <span class="font-mono text-2xs text-smoke tracking-wider">GF</span>
                        )}
                        {item.dietary.includes('vegan') && (
                          <span class="font-mono text-2xs text-smoke tracking-wider">VG</span>
                        )}
                        {item.dietary.includes('spicy') && (
                          <span class="font-mono text-2xs text-crimson-400 tracking-wider">🌶</span>
                        )}
                      </footer>
                    )}

                  </li>
                ))}
            </ul>
          </div>
        ))}

      </section>
    ))}
  </div>

  <!-- ─── Menu CTA ──────────────────────────────────────────────────────── -->
  <section
    aria-label="Reserve or order online"
    class="py-16 bg-velvet border-t border-gold/10 text-center"
  >
    <div class="max-w-layout mx-auto px-gutter">
      <p class="font-serif text-2xl font-light text-parchment mb-8">
        Ready to experience it in person?
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href={import.meta.env.PUBLIC_RESERVATIONS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="eyebrow px-8 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-base ease-luxury rounded-sm"
        >
          Reserve a Table
        </a>
        <a
          href={import.meta.env.PUBLIC_ORDER_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="eyebrow px-8 py-4 border border-gold/40 text-gold hover:border-gold hover:text-parchment transition-all duration-base ease-luxury rounded-sm"
        >
          Order Online
        </a>
      </div>
    </div>
  </section>

</Layout>
