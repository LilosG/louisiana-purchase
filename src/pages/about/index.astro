---
import { getSingleton, resolveContent } from '../../content/siteData';
// src/pages/about/index.astro
// Louisiana Purchase — About Page
// Targets: "about louisiana purchase", "creole restaurant north park", "chef quinnton austin san diego"

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import AlternatingRow from '../../components/ui/AlternatingRow.astro';
import StatBar from '../../components/ui/StatBar.astro';
import CTABand from '../../components/ui/CTABand.astro';
import FourColumnGrid from '../../components/ui/FourColumnGrid.astro';
import { IMAGES } from '../../assets/images';
const pageContent = await getSingleton('about', 'about');
const blocks = pageContent.blocks.map((block: any) => resolveContent(block.props, IMAGES, import.meta.env));
---

<Layout {...blocks[0]}>

  <PageHero {...blocks[1]} />

  <StatBar {...blocks[2]} />

  <!-- ─── The Story ─────────────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[3]} />

  <!-- ─── Chef Quinnton Austin ─────────────────────────────────────────── -->
  <AlternatingRow {...blocks[4]} />

  <!-- ─── The Bar Program ──────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[5]} />

  <!-- ─── What We Offer ────────────────────────────────────────────────── -->
  <section aria-labelledby="offerings-heading" class="bg-velvet py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[6]} />

      <FourColumnGrid {...blocks[7]} />

    </div>
  </section>

  <!-- ─── North Park ───────────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[8]} />

  <CTABand {...blocks[9]} />

</Layout>
