---
import { getSingleton, resolveContent, buildEnv } from '../../content/siteData';
// src/pages/events/index.astro
// Louisiana Purchase — Events & Happenings Hub Page
// Targets: "events north park san diego", "mardi gras san diego", "live music north park"

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import AlternatingRow from '../../components/ui/AlternatingRow.astro';
import StatBar from '../../components/ui/StatBar.astro';
import CTABand from '../../components/ui/CTABand.astro';
import FourColumnGrid from '../../components/ui/FourColumnGrid.astro';
import { IMAGES } from '../../assets/images';
import { Image } from 'astro:assets';
import { getOrderedCollection } from '../../content/siteData';

const eventCategoryCards = (await getOrderedCollection('eventCategoryCards')).map((card) => ({
  ...card,
  image: IMAGES[card.image as keyof typeof IMAGES],
}));
const pageContent = await getSingleton('eventsIndexPage', 'page');
const venue = await getSingleton('venueSettings', 'settings');
const VENUE_SOCIAL = venue.social;
const blocks = (Array.isArray(pageContent.blocks) ? pageContent.blocks : []).map((block: any) => resolveContent(block?.props ?? {}, IMAGES, buildEnv(venue, import.meta.env)));
const updatesTitle = `\n${pageContent.updates.title}`;
---

<Layout {...blocks[0]}>

  <PageHero {...blocks[1]} />

  <StatBar {...blocks[2]} />

  <!-- ─── What Happens Here ────────────────────────────────────────────── -->
  <AlternatingRow {...blocks[3]} />

  <!-- ─── Event Types ──────────────────────────────────────────────────── -->
  <section aria-labelledby="event-types-heading" class="bg-velvet py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">

      <SectionHeader {...blocks[4]} />

      <FourColumnGrid
        cols={4}
        dark={false}
        divided={true}
        cards={eventCategoryCards}
      />

    </div>
  </section>

  <!-- ─── Stay in the Loop ─────────────────────────────────────────────── -->
  <section aria-labelledby="updates-heading" class="bg-obsidian py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <div>
          <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold mb-3" set:text={pageContent.updates.eyebrow}></p>
          <h2 id="updates-heading" class="font-serif font-light text-parchment tracking-[-0.02em] leading-[1.05] mb-5" style="font-size: clamp(2rem, 4vw, 3rem);">{updatesTitle}<br /><span class="italic text-gold" set:text={pageContent.updates.titleItalic}></span>
          </h2>
          <p class="font-sans font-light text-smoke leading-relaxed text-[0.9375rem] mb-8 max-w-[44ch]" set:html={`\n${pageContent.updates.body}\n`}></p>
          <div class="flex flex-wrap gap-4">
            <a
              href={VENUE_SOCIAL.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-[280ms]"
              set:text={`\n${pageContent.updates.instagramLabel}\n`}
            ></a>
            <a
              href={VENUE_SOCIAL.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 border border-gold/40 text-gold hover:border-gold hover:bg-gold/5 transition-all duration-[280ms]"
              set:text={`\n${pageContent.updates.facebookLabel}\n`}
            ></a>
          </div>
        </div>

        <div class="overflow-hidden aspect-[4/3]">
          <Image
            src={IMAGES[pageContent.updates.image as keyof typeof IMAGES]}
            alt={pageContent.updates.imageAlt}
            class="w-full h-full object-cover object-center"
            loading="lazy"
            decoding="async"
            format="webp"
            widths={[480, 800, 1200, 1600]}
            sizes="(min-width: 1024px) 50vw, 100vw"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ─── Private Events Callout ───────────────────────────────────────── -->
  <AlternatingRow {...blocks[5]} />

  <CTABand {...blocks[6]} />

</Layout>
