---
import { getSingleton, resolveContent } from '../../content/siteData';
// src/pages/brunch/index.astro
// Louisiana Purchase — Brunch Hub Page
// Slug: /brunch — permanent URL

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import AlternatingRow from '../../components/ui/AlternatingRow.astro';
import StatBar from '../../components/ui/StatBar.astro';
import CTABand from '../../components/ui/CTABand.astro';
import MenuShowcase from '../../components/ui/MenuShowcase.astro';
import { IMAGES } from '../../assets/images';
import { Image } from 'astro:assets';
import { getOrderedCollection } from '../../content/siteData';

const brunchFaqs = await getOrderedCollection('brunchFaqs');
const pageContent = await getSingleton('brunchPage', 'page');
const venue = await getSingleton('venueSettings', 'settings');
const CANONICAL_DOMAIN = venue.domain;
const VENUE_ADDRESS = venue.address;
const BRUNCH_HOURS = venue.brunchHours;

const brunchSchema = {
  '@context': 'https://schema.org',
  '@type': 'FoodEstablishment',
  name: pageContent.seo.schemaName,
  description: pageContent.seo.schemaDescription,
  url: `${import.meta.env.PUBLIC_SITE_URL || CANONICAL_DOMAIN}/brunch`,
  servesCuisine: ['Creole', 'Southern American', 'New Orleans'],
  address: {
    '@type': 'PostalAddress',
    streetAddress: VENUE_ADDRESS.street,
    addressLocality: VENUE_ADDRESS.city,
    addressRegion: VENUE_ADDRESS.state,
    postalCode: VENUE_ADDRESS.zip,
    addressCountry: VENUE_ADDRESS.country,
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'https://schema.org/Saturday', opens: BRUNCH_HOURS.opens, closes: BRUNCH_HOURS.closes },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'https://schema.org/Sunday',   opens: BRUNCH_HOURS.opens, closes: BRUNCH_HOURS.closes },
  ],
};
const blocks = pageContent.blocks.map((block: any) => resolveContent(block.props, IMAGES, import.meta.env));
const privateBrunchTitle = `\n${pageContent.privateBrunch.title}`;
---

<Layout
  title={pageContent.seo.title}
  description={pageContent.seo.description}
  canonical={pageContent.seo.canonical}
  schema={brunchSchema}
  breadcrumbs={pageContent.seo.breadcrumbs}
>

  <PageHero {...blocks[0]} />

  <StatBar {...blocks[1]} />

  <AlternatingRow {...blocks[2]} />

  <section aria-labelledby="brunch-menu-heading" class="bg-velvet py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <SectionHeader {...blocks[3]} />
      <MenuShowcase section="brunch" category="brunch-plates" cols={3} dark={false} divided={true} />
      <div class="text-center mt-10">
        <a href={pageContent.menuLink.href} class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 border border-gold/40 text-gold hover:border-gold hover:bg-gold/5 transition-all duration-[280ms]" set:text={`\n${pageContent.menuLink.label}\n`}></a>
      </div>
    </div>
  </section>

  <AlternatingRow {...blocks[4]} />

  <section aria-labelledby="private-brunch-heading" class="bg-velvet py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold mb-3" set:text={pageContent.privateBrunch.eyebrow}></p>
          <h2 id="private-brunch-heading" class="font-serif font-light text-parchment tracking-[-0.02em] leading-[1.05] mb-5" style="font-size: clamp(2rem, 4vw, 3rem);">{privateBrunchTitle}<br /><span class="italic text-gold" set:text={pageContent.privateBrunch.titleItalic}></span>
          </h2>
          <p class="font-sans font-light text-smoke leading-relaxed text-[0.9375rem] mb-6 max-w-[46ch]" set:text={`\n${pageContent.privateBrunch.body}\n`}></p>
          <ul role="list" class="flex flex-col gap-2.5 mb-8">
            {pageContent.privateBrunch.benefits.map((item: string) => (
              <li class="flex items-start gap-3 font-sans text-sm text-parchment/70">
                <span class="text-gold text-[0.5rem] mt-1.5 shrink-0">{pageContent.privateBrunch.listMarker}</span>
                {item}
              </li>
            ))}
          </ul>
          <a href={pageContent.privateBrunch.cta.href} class="inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm px-8 py-4 bg-gold text-obsidian hover:bg-gold-200 transition-all duration-[280ms]" set:text={`\n${pageContent.privateBrunch.cta.label}\n`}></a>
        </div>
        <div class="overflow-hidden aspect-[4/3] lg:aspect-auto lg:h-[480px]">
          <Image src={IMAGES[pageContent.privateBrunch.image as keyof typeof IMAGES]} alt={pageContent.privateBrunch.imageAlt} class="w-full h-full object-cover object-center" loading="lazy" decoding="async" format="webp" widths={[480, 800, 1200, 1600]} sizes="(min-width: 1024px) 50vw, 100vw" />
        </div>
      </div>
    </div>
  </section>

  <section aria-labelledby="brunch-faq-heading" class="bg-obsidian py-20 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <SectionHeader {...blocks[5]} />
      <dl class="divide-y divide-gold/10 max-w-[80ch] mx-auto">
        {brunchFaqs.map((faq) => (
          <div class="py-5 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-12 reveal">
            <dt class="font-serif font-light text-parchment text-base">{faq.q}</dt>
            <dd class="font-sans font-light text-smoke leading-relaxed text-sm">{faq.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <CTABand {...blocks[6]} />

</Layout>
