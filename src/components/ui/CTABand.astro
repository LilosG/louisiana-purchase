---
// src/components/ui/CTABand.astro
// Louisiana Purchase — Full-Width CTA Band Component
// Tailwind v4: standard utility classes only.

interface CTAButton {
  label:     string;
  href:      string;
  external?: boolean;
  variant:   'gold' | 'outline';
}

interface Props {
  eyebrow?:  string;
  title:     string;
  subtitle?: string;
  ctas:      CTAButton[];
  image?:    string;
  imageAlt?: string;
  dark?:     boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  ctas,
  image,
  imageAlt = '',
  dark = false,
} = Astro.props;
---

<section
  aria-label={title}
  class:list={[
    'relative overflow-hidden',
    image ? 'py-24 md:py-36' : 'py-20 md:py-28',
    !image && dark  ? 'bg-obsidian' : '',
    !image && !dark ? 'bg-velvet'   : '',
  ]}
>
  <div class="absolute top-0 left-0 right-0 h-px bg-[linear-gradient(to_right,transparent,rgba(201,168,76,0.40),transparent)]" aria-hidden="true"></div>

  {image && (
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover object-center"
        loading="lazy"
        decoding="async"
        width="1600"
        height="900"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-obsidian/70 via-obsidian/80 to-obsidian/90"></div>
    </div>
  )}

  <div class="relative z-10 max-w-[1280px] mx-auto px-6 text-center">

    {eyebrow && (
      <p class="font-sans text-[0.625rem] font-medium tracking-[0.32em] uppercase text-gold mb-4">
        {eyebrow}
      </p>
    )}

    <h2
      class="font-serif font-light text-parchment tracking-[-0.02em] leading-tight mb-4"
      style="font-size: clamp(1.875rem, 4vw, 3rem);"
    >
      {title}
    </h2>

    {subtitle && (
      <p class="font-sans font-light text-smoke leading-relaxed max-w-[52ch] mx-auto mb-10"
         style="font-size: clamp(0.875rem, 1.25vw, 1rem);">
        {subtitle}
      </p>
    )}

    <div class="flex flex-col sm:flex-row justify-center gap-4">
      {ctas.map((cta) => (
        <a
          href={cta.href}
          target={cta.external ? '_blank' : undefined}
          rel={cta.external ? 'noopener noreferrer' : undefined}
          class:list={[
            'inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm transition-all duration-[280ms] ease-[cubic-bezier(0.25,0.1,0.25,1)] whitespace-nowrap',
            {
              'px-10 py-4 bg-gold text-obsidian hover:bg-gold-200':                           cta.variant === 'gold',
              'px-10 py-4 border border-gold/40 text-gold hover:border-gold hover:bg-gold/5': cta.variant === 'outline',
            }
          ]}
        >
          {cta.label}
        </a>
      ))}
    </div>

  </div>

  <div class="absolute bottom-0 left-0 right-0 h-px bg-[linear-gradient(to_right,transparent,rgba(201,168,76,0.40),transparent)]" aria-hidden="true"></div>

</section>
