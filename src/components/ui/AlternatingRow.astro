---
// src/components/ui/AlternatingRow.astro
// Louisiana Purchase — Asymmetric Editorial Row Component
// Tailwind v4: standard utility classes only.

interface Props {
  image:        string;
  imageAlt:     string;
  eyebrow?:     string;
  title:        string;
  titleItalic?: string;
  body:         string[];
  ctas?:        { label: string; href: string; external?: boolean; variant: 'gold' | 'outline' | 'text' }[];
  facts?:       { label: string; value: string }[];
  reverse?:     boolean;
  dark?:        boolean;
  headingId?:   string;
}

const {
  image,
  imageAlt,
  eyebrow,
  title,
  titleItalic,
  body,
  ctas = [],
  facts = [],
  reverse = false,
  dark = true,
  headingId,
} = Astro.props;
---

<div class:list={[
  'grid grid-cols-1 lg:grid-cols-2',
  dark ? 'bg-obsidian' : 'bg-velvet',
]}>

  <div class:list={[
    'relative overflow-hidden min-h-[50vw] lg:min-h-[65vh]',
    reverse ? 'lg:order-2' : 'lg:order-1',
  ]}>
    <img
      src={image}
      alt={imageAlt}
      class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-[800ms] ease-[cubic-bezier(0.25,0.1,0.25,1)] hover:scale-[1.03]"
      loading="lazy"
      decoding="async"
      width="1600"
      height="1065"
    />
    <div class:list={[
      'absolute top-0 bottom-0 w-px opacity-40',
      'bg-[linear-gradient(to_bottom,transparent,rgba(201,168,76,0.60),transparent)]',
      reverse ? 'left-0' : 'right-0',
    ]} aria-hidden="true"></div>
  </div>

  <div class:list={[
    'flex flex-col justify-center px-6 py-16 md:py-24 lg:px-14 xl:px-20',
    reverse ? 'lg:order-1' : 'lg:order-2',
  ]}>

    {eyebrow && (
      <p class="font-sans text-[0.625rem] font-medium tracking-[0.32em] uppercase text-gold mb-4 reveal">
        {eyebrow}
      </p>
    )}

    <h2
      id={headingId}
      class="font-display font-light text-parchment tracking-[-0.03em] leading-none mb-5 reveal"
      style="font-size: clamp(2rem, 4vw, 3.25rem);"
    >
      {title}
      {titleItalic && (
        <span class="block font-serif italic font-light text-gold tracking-[-0.01em]" style="font-size: clamp(1.875rem, 3.75vw, 3rem);">
          {titleItalic}
        </span>
      )}
    </h2>

    {body.map((paragraph) => (
      <p class="font-sans font-light text-smoke leading-relaxed mb-4 reveal" style="font-size: clamp(0.9375rem, 1.25vw, 1rem);">
        {paragraph}
      </p>
    ))}

    {facts.length > 0 && (
      <dl class="grid grid-cols-2 gap-x-8 gap-y-4 mt-6 mb-8 pt-6 border-t border-gold/15 reveal">
        {facts.map((fact) => (
          <div>
            <dt class="font-sans text-[0.625rem] font-medium tracking-[0.32em] uppercase text-gold mb-1">
              {fact.label}
            </dt>
            <dd class="font-serif font-light text-parchment text-lg">
              {fact.value}
            </dd>
          </div>
        ))}
      </dl>
    )}

    {ctas.length > 0 && (
      <div class="flex flex-wrap gap-4 mt-6 reveal">
        {ctas.map((cta) => (
          <a
            href={cta.href}
            target={cta.external ? '_blank' : undefined}
            rel={cta.external ? 'noopener noreferrer' : undefined}
            class:list={[
              'inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm transition-all duration-[280ms] ease-[cubic-bezier(0.25,0.1,0.25,1)] whitespace-nowrap',
              {
                'px-8 py-4 bg-gold text-obsidian hover:bg-gold-200':                           cta.variant === 'gold',
                'px-8 py-4 border border-gold/40 text-gold hover:border-gold hover:bg-gold/5': cta.variant === 'outline',
                'text-gold hover:text-gold-200':                                                cta.variant === 'text',
              }
            ]}
          >
            {cta.label}
          </a>
        ))}
      </div>
    )}

    <slot />

  </div>

</div>
