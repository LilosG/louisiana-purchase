---
// src/components/ui/StatBar.astro
// Louisiana Purchase — Compact Stat / Metric Bar
// Mirrors the homepage hero bar proportions — tight, refined, not oversized.

interface Stat {
  value:     string;
  label:     string;
  href?:     string;
  external?: boolean;
}

interface Props {
  stats: Stat[];
  dark?: boolean;
}

const { stats, dark = true } = Astro.props;
---

<div
  class:list={[
    'grid border-y border-gold/20',
    dark ? 'bg-obsidian' : 'bg-velvet',
    stats.length === 2 ? 'grid-cols-2' : '',
    stats.length === 3 ? 'grid-cols-3' : '',
    stats.length === 4 ? 'grid-cols-2 md:grid-cols-4' : '',
    stats.length > 4  ? 'grid-cols-2 md:grid-cols-3 lg:grid-cols-6' : '',
  ]}
  role="list"
>
  {stats.map((stat, i) => (
    <div
      class:list={[
        'flex flex-col items-center justify-center text-center gap-1.5 py-6 px-4',
        i < stats.length - 1 ? 'border-r border-gold/12' : '',
      ]}
      role="listitem"
    >
      {stat.href ? (
        <a
          href={stat.href}
          target={stat.external ? '_blank' : undefined}
          rel={stat.external ? 'noopener noreferrer' : undefined}
          class="font-serif font-light text-parchment leading-none tracking-[-0.01em] hover:text-gold transition-colors duration-[280ms]"
          style="font-size: clamp(1.125rem, 2vw, 1.375rem);"
        >
          {stat.value}
        </a>
      ) : (
        <span
          class="font-serif font-light text-parchment leading-none tracking-[-0.01em]"
          style="font-size: clamp(1.125rem, 2vw, 1.375rem);"
        >
          {stat.value}
        </span>
      )}
      <span class="font-sans text-[0.5rem] font-medium tracking-[0.28em] uppercase text-gold/60">
        {stat.label}
      </span>
    </div>
  ))}
</div>
