---
// src/components/ui/StatBar.astro
// Louisiana Purchase — Stat / Metric Bar Component
// Tailwind v4: standard utility classes only.

interface Stat {
  value:     string;
  label:     string;
  href?:     string;
  external?: boolean;
}

interface Props {
  stats: Stat[];
  dark?: boolean;
}

const { stats, dark = true } = Astro.props;
---

<div
  class:list={[
    'relative grid border-y border-gold/20',
    dark ? 'bg-obsidian' : 'bg-velvet',
    stats.length === 2 ? 'grid-cols-2' : '',
    stats.length === 3 ? 'grid-cols-3' : '',
    stats.length === 4 ? 'grid-cols-2 md:grid-cols-4' : '',
    stats.length > 4  ? 'grid-cols-2 md:grid-cols-3 lg:grid-cols-6' : '',
  ]}
  role="list"
>
  {stats.map((stat, i) => (
    <div
      class:list={[
        'flex flex-col items-center justify-center text-center gap-2 py-8 px-4 md:py-10',
        i < stats.length - 1 ? 'border-r border-gold/15' : '',
      ]}
      role="listitem"
    >
      {stat.href ? (
        <a
          href={stat.href}
          target={stat.external ? '_blank' : undefined}
          rel={stat.external ? 'noopener noreferrer' : undefined}
          class="font-display font-light text-gold leading-none tracking-[-0.03em] hover:text-gold-200 transition-colors duration-[280ms] ease-[cubic-bezier(0.25,0.1,0.25,1)]"
          style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);"
        >
          {stat.value}
        </a>
      ) : (
        <span
          class="font-display font-light text-gold leading-none tracking-[-0.03em]"
          style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);"
        >
          {stat.value}
        </span>
      )}
      <span class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-smoke">
        {stat.label}
      </span>
    </div>
  ))}
</div>
