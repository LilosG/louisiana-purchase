---
// src/components/ui/PageHero.astro
// Louisiana Purchase — Shared Page Hero Component
// Tailwind v4: standard utility classes only.

interface CTAButton {
  label:     string;
  href:      string;
  external?: boolean;
  variant:   'gold' | 'outline' | 'text';
}

interface Props {
  eyebrow?:     string;
  title:        string;
  titleItalic?: string;
  subtitle?:    string;
  image?:       string;
  imageAlt?:    string;
  ctas?:        CTAButton[];
  headlineId?:  string;
  centered?:    boolean;
}

const {
  eyebrow,
  title,
  titleItalic,
  subtitle,
  image,
  imageAlt = '',
  ctas = [],
  headlineId = 'page-headline',
  centered = false,
} = Astro.props;
---

<section
  aria-labelledby={headlineId}
  class="relative flex flex-col justify-end min-h-[72vh] overflow-hidden bg-obsidian"
>
  {image && (
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover object-center"
        loading="eager"
        decoding="async"
        width="1600"
        height="900"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-obsidian/20 via-obsidian/55 to-obsidian/95"></div>
    </div>
  )}

  {!image && (
    <div class="absolute inset-0 z-0 bg-[linear-gradient(135deg,#1C1419_0%,#0A0806_100%)] opacity-60" aria-hidden="true"></div>
  )}

  <div class="absolute top-0 left-0 right-0 h-px bg-[linear-gradient(to_right,transparent,rgba(201,168,76,0.40),transparent)] z-10" aria-hidden="true"></div>

  <div class={`relative z-10 max-w-[1280px] mx-auto w-full px-6 pb-14 md:pb-20 pt-24 md:pt-32 ${centered ? 'text-center' : ''}`}>

    {eyebrow && (
      <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold mb-4 md:mb-5">
        {eyebrow}
      </p>
    )}

    <h1
      id={headlineId}
      class="font-serif font-light text-parchment tracking-[-0.02em] leading-[1.05] mb-4 animate-fade-up"
      style="font-size: clamp(2.75rem, 7vw, 6rem);"
    >
      {title}
      {titleItalic && (
        <span class="block italic font-light text-gold" style="font-size: clamp(2.5rem, 6.5vw, 5.5rem);">
          {titleItalic}
        </span>
      )}
    </h1>

    {subtitle && (
      <p class="font-sans font-light text-parchment/70 max-w-[52ch] leading-relaxed mb-8 animate-fade-in text-[0.9375rem] md:text-base">
        {subtitle}
      </p>
    )}

    {ctas.length > 0 && (
      <div class={`flex flex-wrap gap-4 ${centered ? 'justify-center' : ''} animate-fade-up`}>
        {ctas.map((cta) => (
          <a
            href={cta.href}
            target={cta.external ? '_blank' : undefined}
            rel={cta.external ? 'noopener noreferrer' : undefined}
            class:list={[
              'inline-flex items-center justify-center font-sans text-[0.625rem] font-medium tracking-[0.24em] uppercase rounded-sm transition-all duration-[280ms] ease-[cubic-bezier(0.25,0.1,0.25,1)] whitespace-nowrap',
              {
                'px-8 py-4 bg-gold text-obsidian hover:bg-gold-200':                               cta.variant === 'gold',
                'px-8 py-4 border border-gold/40 text-gold hover:border-gold hover:bg-gold/5':     cta.variant === 'outline',
                'text-gold hover:text-gold-200':                                                    cta.variant === 'text',
              }
            ]}
          >
            {cta.label}
          </a>
        ))}
      </div>
    )}

    <slot />

  </div>
</section>
