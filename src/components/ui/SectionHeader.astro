---
// src/components/ui/SectionHeader.astro
// Louisiana Purchase — Shared Section Header Component
// font-serif for titles — matches homepage section title treatment.

interface Props {
  eyebrow?:     string;
  title:        string;
  titleItalic?: string;
  subtitle?:    string;
  centered?:    boolean;
  light?:       boolean;
  id?:          string;
}

const {
  eyebrow,
  title,
  titleItalic,
  subtitle,
  centered = true,
  light = false,
  id,
} = Astro.props;
---

<header class:list={['mb-10 md:mb-14', { 'text-center': centered }]}>

  {eyebrow && (
    <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold mb-3">
      {eyebrow}
    </p>
  )}

  <h2
    id={id}
    class:list={[
      'font-serif font-light tracking-[-0.02em] leading-[1.05] mb-3',
      light ? 'text-obsidian' : 'text-parchment',
    ]}
    style="font-size: clamp(2.25rem, 5vw, 3.75rem);"
  >
    {title}
    {titleItalic && (
      <span
        class:list={[
          'block italic font-light',
          light ? 'text-obsidian/80' : 'text-gold',
        ]}
        style="font-size: clamp(2rem, 4.5vw, 3.5rem);"
      >
        {titleItalic}
      </span>
    )}
  </h2>

  {subtitle && (
    <p
      class:list={[
        'font-sans font-light leading-relaxed max-w-[58ch] text-[0.9375rem]',
        centered ? 'mx-auto' : '',
        light ? 'text-obsidian/60' : 'text-smoke',
      ]}
    >
      {subtitle}
    </p>
  )}

</header>
