---
// src/components/ui/FourColumnGrid.astro
// Louisiana Purchase — Editorial Card Grid Component
// Tailwind v4: standard utility classes only.

interface GridCard {
  image?:     string;
  imageAlt?:  string;
  eyebrow?:   string;
  title:      string;
  body?:      string;
  meta?:      string;
  href?:      string;
  external?:  boolean;
  linkLabel?: string;
}

interface Props {
  cards:    GridCard[];
  cols?:    2 | 3 | 4;
  dark?:    boolean;
  divided?: boolean;
}

const {
  cards,
  cols = 4,
  dark = true,
  divided = true,
} = Astro.props;

const colClass = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-2 lg:grid-cols-4',
}[cols];
---

<ul
  role="list"
  class:list={[
    'grid',
    colClass,
    divided ? 'gap-px bg-gold/10' : 'gap-6',
  ]}
>
  {cards.map((card) => (
    <li class:list={[dark ? 'bg-obsidian' : 'bg-velvet', 'flex flex-col group reveal']}>

      {card.href ? (
        <a
          href={card.href}
          target={card.external ? '_blank' : undefined}
          rel={card.external ? 'noopener noreferrer' : undefined}
          class="flex flex-col h-full"
          aria-label={card.title}
        >
          {card.image && (
            <div class="aspect-[3/4] overflow-hidden">
              <img
                src={card.image}
                alt={card.imageAlt || card.title}
                class="w-full h-full object-cover object-center transition-transform duration-[800ms] ease-[cubic-bezier(0.25,0.1,0.25,1)] group-hover:scale-[1.05]"
                loading="lazy"
                decoding="async"
                width="800"
                height="1067"
              />
            </div>
          )}
          <div class="flex flex-col flex-1 gap-2 p-5 md:p-6 border-t border-gold/10">
            {card.eyebrow && (
              <p class="font-sans text-[0.625rem] font-medium tracking-[0.32em] uppercase text-gold">
                {card.eyebrow}
              </p>
            )}
            <h3 class="font-serif font-light text-parchment leading-snug group-hover:text-gold transition-colors duration-[280ms] ease-[cubic-bezier(0.25,0.1,0.25,1)]"
                style="font-size: clamp(1rem, 1.5vw, 1.125rem);">
              {card.title}
            </h3>
            {card.body && (
              <p class="font-sans font-light text-smoke leading-relaxed flex-1 text-sm">
                {card.body}
              </p>
            )}
            {card.meta && (
              <p class="font-mono text-sm text-gold mt-auto pt-2">
                {card.meta}
              </p>
            )}
            {card.linkLabel && (
              <span class="font-sans text-[0.625rem] font-medium tracking-[0.16em] uppercase text-gold mt-2 group-hover:translate-x-1 transition-transform duration-[280ms] inline-block">
                {card.linkLabel} →
              </span>
            )}
          </div>
        </a>
      ) : (
        <>
          {card.image && (
            <div class="aspect-[3/4] overflow-hidden">
              <img
                src={card.image}
                alt={card.imageAlt || card.title}
                class="w-full h-full object-cover object-center transition-transform duration-[800ms] ease-[cubic-bezier(0.25,0.1,0.25,1)] group-hover:scale-[1.05]"
                loading="lazy"
                decoding="async"
                width="800"
                height="1067"
              />
            </div>
          )}
          <div class="flex flex-col flex-1 gap-2 p-5 md:p-6 border-t border-gold/10">
            {card.eyebrow && (
              <p class="font-sans text-[0.625rem] font-medium tracking-[0.32em] uppercase text-gold">
                {card.eyebrow}
              </p>
            )}
            <h3 class="font-serif font-light text-parchment leading-snug"
                style="font-size: clamp(1rem, 1.5vw, 1.125rem);">
              {card.title}
            </h3>
            {card.body && (
              <p class="font-sans font-light text-smoke leading-relaxed flex-1 text-sm">
                {card.body}
              </p>
            )}
            {card.meta && (
              <p class="font-mono text-sm text-gold mt-auto pt-2">
                {card.meta}
              </p>
            )}
          </div>
        </>
      )}

    </li>
  ))}
</ul>
