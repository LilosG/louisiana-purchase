---
// src/components/ui/FourColumnGrid.astro
// Louisiana Purchase — Editorial Card Grid Component
// Matches homepage cocktail grid card treatment — solid dark cards, image + copy.

import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GridCard {
  image?:     ImageMetadata;
  imageFallback?: boolean;
  imageAlt?:  string;
  eyebrow?:   string;
  title:      string;
  body?:      string;
  meta?:      string;
  href?:      string;
  external?:  boolean;
  linkLabel?: string;
}

interface Props {
  cards:    GridCard[];
  cols?:    2 | 3 | 4;
  dark?:    boolean;
  divided?: boolean;
}

const {
  cards = [],
  cols = 4,
  dark = true,
  divided = true,
} = Astro.props;

const colClass = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-2 lg:grid-cols-4',
}[cols];

const cardBg = dark ? 'bg-obsidian-800' : 'bg-velvet-800';
---

<ul
  role="list"
  class:list={[
    'grid',
    colClass,
    divided ? 'gap-px bg-gold/10' : 'gap-4',
  ]}
>
  {cards.map((card) => (
    <li class:list={[cardBg, 'flex flex-col group reveal']}>

      {card.href ? (
        <a
          href={card.href}
          target={card.external ? '_blank' : undefined}
          rel={card.external ? 'noopener noreferrer' : undefined}
          class="flex flex-col h-full"
          aria-label={card.title}
        >
          {card.image ? (
            <div class="aspect-[3/4] overflow-hidden">
              <Image
                src={card.image}
                alt={card.imageAlt || card.title}
                class="w-full h-full object-cover object-center transition-transform duration-[700ms] ease-[cubic-bezier(0.25,0.1,0.25,1)] group-hover:scale-[1.05]"
                loading="lazy"
                decoding="async"
                format="webp"
                widths={[300, 500, 800]}
                sizes="(min-width: 1024px) 25vw, 50vw"
              />
            </div>
          ) : card.imageFallback && (
            <div
              class="aspect-[3/4] grid place-items-center overflow-hidden bg-[radial-gradient(circle_at_50%_38%,rgba(214,170,98,0.12),transparent_58%)]"
              aria-hidden="true"
            >
              <span class="grid h-14 w-14 place-items-center rounded-full border border-gold/25 font-serif text-lg text-gold/60">LP</span>
            </div>
          )}
          <div class="flex flex-col flex-1 gap-2 p-6 md:p-7">
            {card.eyebrow && (
              <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold">
                {card.eyebrow}
              </p>
            )}
            <h3 class="font-serif font-light text-parchment leading-snug group-hover:text-gold transition-colors duration-[280ms]"
                style="font-size: clamp(1rem, 1.5vw, 1.125rem);">
              {card.title}
            </h3>
            {card.body && (
              <p class="font-sans font-light text-smoke leading-relaxed flex-1 text-sm mt-1">
                {card.body}
              </p>
            )}
            {card.meta && (
              <p class="font-mono text-sm text-gold mt-auto pt-3 border-t border-gold/10">
                {card.meta}
              </p>
            )}
            {card.linkLabel && (
              <span class="font-sans text-[0.5625rem] font-medium tracking-[0.16em] uppercase text-gold mt-2 group-hover:translate-x-1 transition-transform duration-[280ms] inline-block">
                {card.linkLabel} →
              </span>
            )}
          </div>
        </a>
      ) : (
        <>
          {card.image ? (
            <div class="aspect-[3/4] overflow-hidden">
              <Image
                src={card.image}
                alt={card.imageAlt || card.title}
                class="w-full h-full object-cover object-center transition-transform duration-[700ms] ease-[cubic-bezier(0.25,0.1,0.25,1)] group-hover:scale-[1.05]"
                loading="lazy"
                decoding="async"
                format="webp"
                widths={[300, 500, 800]}
                sizes="(min-width: 1024px) 25vw, 50vw"
              />
            </div>
          ) : card.imageFallback && (
            <div
              class="aspect-[3/4] grid place-items-center overflow-hidden bg-[radial-gradient(circle_at_50%_38%,rgba(214,170,98,0.12),transparent_58%)]"
              aria-hidden="true"
            >
              <span class="grid h-14 w-14 place-items-center rounded-full border border-gold/25 font-serif text-lg text-gold/60">LP</span>
            </div>
          )}
          <div class="flex flex-col flex-1 gap-2 p-6 md:p-7">
            {card.eyebrow && (
              <p class="font-sans text-[0.5625rem] font-medium tracking-[0.28em] uppercase text-gold">
                {card.eyebrow}
              </p>
            )}
            <h3 class="font-serif font-light text-parchment leading-snug"
                style="font-size: clamp(1rem, 1.5vw, 1.125rem);">
              {card.title}
            </h3>
            {card.body && (
              <p class="font-sans font-light text-smoke leading-relaxed flex-1 text-sm mt-1">
                {card.body}
              </p>
            )}
            {card.meta && (
              <p class="font-mono text-sm text-gold mt-auto pt-3 border-t border-gold/10">
                {card.meta}
              </p>
            )}
          </div>
        </>
      )}

    </li>
  ))}
</ul>
