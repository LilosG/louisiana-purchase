---
// src/components/layout/SiteFooter.astro
// Louisiana Purchase — Site Footer
import { GPH_NETWORK, GRIND_AND_PROSPER_URL } from '../../data/gphNetwork';
import { getSingleton } from '../../content/siteData';

const venue = await getSingleton('venueSettings', 'settings');
const eventsConfig = await getSingleton('eventsConfig', 'config');
const footer = await getSingleton('footer', 'footer');

const portfolio = GPH_NETWORK.filter((v) => v.url !== venue.domain);

// Pages under /private-events/ embed the inquiry form directly and already
// have the #event-inquiry anchor on the page; everywhere else needs to
// navigate to /private-events first.
const isOnPrivateEventsPage = Astro.url.pathname.startsWith('/private-events');
const privateEventsHref = isOnPrivateEventsPage
  ? `#${eventsConfig.privateEventsFormAnchor}`
  : `/private-events#${eventsConfig.privateEventsFormAnchor}`;
const bottomDescription = `\n${venue.address.neighborhood}, ${venue.address.city} &nbsp;&middot;&nbsp; ${footer.bottomCuisine.replace('&', '&amp;')}\n`;
---

<footer role="contentinfo" aria-label={footer.ariaLabels.footer} class="site-footer">

  <div class="site-footer__rule" aria-hidden="true"></div>

  <div class="site-footer__inner">

    <!-- Top grid -->
    <div class="site-footer__grid">

      <!-- Brand column -->
      <div class="site-footer__brand-col">
        <a href="/" class="site-footer__wordmark" aria-label={footer.wordmark.homeAriaLabel}>
          <span class="site-footer__wordmark-top">{footer.wordmark.top}</span>
          <span class="site-footer__wordmark-bottom">{footer.wordmark.bottom}</span>
        </a>
        <p class="site-footer__tagline" set:text={`\n${footer.tagline}\n`}></p>
        <address class="site-footer__address">
          <a
            href={venue.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="site-footer__address-link"
          >
            {venue.address.street}<br />
            {venue.address.neighborhood}, {venue.address.city}, {venue.address.state} {venue.address.zip}
          </a>
        </address>
        <div class="site-footer__social" aria-label={footer.ariaLabels.social}>
          <a
            href={venue.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={footer.ariaLabels.instagram}
            class="site-footer__social-link"
            set:text={`\n${footer.socialLabels.instagram}\n`}
          ></a>
          <a
            href={venue.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={footer.ariaLabels.facebook}
            class="site-footer__social-link"
            set:text={`\n${footer.socialLabels.facebook}\n`}
          ></a>
        </div>
      </div>

      <!-- Explore column -->
      <nav aria-labelledby="footer-explore-heading" class="site-footer__nav-col">
        <h3 id="footer-explore-heading" class="site-footer__col-heading">{footer.columnHeadings.explore}</h3>
        <ul role="list" class="site-footer__nav-list">
          {(Array.isArray(footer.exploreLinks) ? footer.exploreLinks : []).map((link: any) => (
            <li>
              <a href={link.href} class="site-footer__nav-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Hours column -->
      <section aria-labelledby="footer-hours-heading" class="site-footer__hours-col">
        <h3 id="footer-hours-heading" class="site-footer__col-heading">{footer.columnHeadings.hours}</h3>
        <dl class="site-footer__hours">
          {(Array.isArray(venue.displayHours) ? venue.displayHours : []).map((h: any) => (
            <div class="site-footer__hour-row">
              <dt>{h.label}</dt>
              <dd>{h.value}</dd>
            </div>
          ))}
        </dl>
        <p class="site-footer__brunch-note">
          {venue.brunchHours.label}: {venue.brunchHours.days} <span class="site-footer__nowrap">{venue.brunchHours.window}</span>
        </p>
        <p class="site-footer__brunch-note">
          {venue.happyHour.label}: {venue.happyHour.days} <span class="site-footer__nowrap">{venue.happyHour.window}</span>
        </p>
      </section>

      <!-- Reserve column -->
      <section aria-labelledby="footer-reserve-heading" class="site-footer__reserve-col">
        <h3 id="footer-reserve-heading" class="site-footer__col-heading">{footer.columnHeadings.reservations}</h3>
        <ul role="list" class="site-footer__nav-list">
          <li>
            <a
              href={import.meta.env.PUBLIC_RESERVATIONS_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="site-footer__nav-link"
              set:text={`\n${footer.reservationLinks.reserveTable}\n`}
            ></a>
          </li>
          <li>
            <a
              href={import.meta.env.PUBLIC_RESERVATIONS_URL_TOAST}
              target="_blank"
              rel="noopener noreferrer"
              class="site-footer__nav-link site-footer__nav-link--secondary"
            >
              Reserve via Toast
            </a>
          </li>
          <li>
            <a
              href={import.meta.env.PUBLIC_ORDER_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="site-footer__nav-link"
              set:text={`\n${footer.reservationLinks.orderOnline}\n`}
            ></a>
          </li>
          <li>
            <a
              href={import.meta.env.PUBLIC_GIFT_CARD_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="site-footer__nav-link"
              set:text={`\n${footer.reservationLinks.giftCards}\n`}
            ></a>
          </li>
          <li>
            <a
              href={privateEventsHref}
              class="site-footer__nav-link"
              set:text={`\n${footer.reservationLinks.privateEvents}\n`}
            ></a>
          </li>
        </ul>
        <a
          href={import.meta.env.PUBLIC_RESERVATIONS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__reserve-btn"
          aria-label={footer.ariaLabels.reserve}
          set:text={`\n${footer.reservationLinks.reserveNow}\n`}
        ></a>
        <a
          href={import.meta.env.PUBLIC_RESERVATIONS_URL_TOAST}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__reserve-btn-secondary"
        >
          Reserve via Toast
        </a>
      </section>

    </div>

    <!-- GPH Network -->
    <div class="site-footer__network">
      <a href={GRIND_AND_PROSPER_URL} target="_blank" rel="noopener noreferrer" class="site-footer__network-label" set:text={`\n${footer.networkLabel}\n`}></a>
      <div class="site-footer__network-links">
        {portfolio.map((v) => (
          <a href={v.url} target="_blank" rel="noopener noreferrer" class="site-footer__network-link">
            {v.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        &copy; {new Date().getFullYear()} {footer.copyrightVenue} &bull; {venue.address.street}, {venue.address.city}, {venue.address.state} {venue.address.zip}
      </p>
      <div class="site-footer__bottom-right">
        <p class="site-footer__sub" set:html={bottomDescription}></p>
        <a href={footer.creditUrl} target="_blank" rel="noopener noreferrer" class="site-footer__lilos-credit" set:text={`\n${footer.creditLabel}\n`}></a>
      </div>
    </div>

  </div>
</footer>

<style>
.site-footer {
  background: var(--color-velvet);
  position: relative;
}

.site-footer__rule {
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(201,168,76,0.45), transparent);
}

.site-footer__inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 5rem 1.5rem 2.5rem;
}

.site-footer__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  padding-bottom: 4rem;
  border-bottom: 1px solid rgba(201,168,76,0.10);
}

@media (min-width: 640px) {
  .site-footer__grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .site-footer__grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 4rem; }
}

/* Brand */
.site-footer__wordmark {
  display: flex;
  flex-direction: column;
  line-height: 1;
  gap: 0.1em;
  margin-bottom: 1.25rem;
  width: fit-content;
}

.site-footer__wordmark-top {
  font-family: var(--font-sans);
  font-size: 0.5rem;
  font-weight: 500;
  letter-spacing: 0.36em;
  text-transform: uppercase;
  color: rgba(201,168,76,0.60);
}

.site-footer__wordmark-bottom {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 400;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  color: var(--color-parchment);
  transition: color 280ms ease;
}

.site-footer__wordmark:hover .site-footer__wordmark-bottom { color: var(--color-gold); }

.site-footer__tagline {
  font-family: var(--font-sans);
  font-size: 0.8125rem;
  color: var(--color-smoke);
  line-height: 1.65;
  margin-bottom: 1rem;
  max-width: 32ch;
}

.site-footer__address {
  font-style: normal;
  margin-bottom: 1.5rem;
}

.site-footer__address-link {
  font-family: var(--font-sans);
  font-size: 0.8125rem;
  color: rgba(242,235,224,0.55);
  line-height: 1.7;
  transition: color 280ms ease;
}

.site-footer__address-link:hover { color: var(--color-gold); }

.site-footer__social {
  display: flex;
  gap: 1.25rem;
}

.site-footer__social-link {
  font-family: var(--font-sans);
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(242,235,224,0.45);
  transition: color 280ms ease;
}

.site-footer__social-link:hover { color: var(--color-gold); }

/* Nav columns */
.site-footer__col-heading {
  font-family: var(--font-sans);
  font-size: 0.5625rem;
  font-weight: 500;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: 1.25rem;
}

.site-footer__nav-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.site-footer__nav-link {
  font-family: var(--font-sans);
  font-size: 0.875rem;
  color: rgba(242,235,224,0.55);
  transition: color 280ms ease;
  line-height: 1.4;
}

.site-footer__nav-link:hover { color: var(--color-parchment); }

.site-footer__nav-link--secondary {
  font-size: 0.75rem;
  opacity: 0.65;
}

/* Hours */
.site-footer__hours {
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
  margin-bottom: 1rem;
}

.site-footer__hour-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 0.375rem 1rem;
}

.site-footer__hour-row dt {
  font-family: var(--font-sans);
  font-size: 0.8125rem;
  color: rgba(242,235,224,0.45);
  white-space: nowrap;
}

.site-footer__hour-row dd {
  font-family: var(--font-sans);
  font-size: 0.8125rem;
  color: rgba(242,235,224,0.70);
  text-align: right;
  white-space: nowrap;
}

.site-footer__brunch-note {
  font-family: var(--font-sans);
  font-size: 0.6875rem;
  color: var(--color-gold);
  opacity: 0.75;
  letter-spacing: 0.04em;
  margin-top: 0.5rem;
}

.site-footer__nowrap {
  white-space: nowrap;
}

/* Reserve btn */
.site-footer__reserve-btn {
  display: inline-flex;
  margin-top: 1.5rem;
  padding: 0.75rem 1.5rem;
  background: var(--color-gold);
  color: var(--color-obsidian);
  font-family: var(--font-sans);
  font-size: 0.5625rem;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  border-radius: 2px;
  transition: background 280ms ease;
  white-space: nowrap;
}

.site-footer__reserve-btn:hover { background: var(--color-gold-light); }

/* Temporary: small secondary reservation button (Toast), while the client
   verifies the new OpenTable system before removing Toast entirely. */
.site-footer__reserve-btn-secondary {
  display: inline-flex;
  margin-top: 0.625rem;
  margin-left: 0.75rem;
  padding: 0.5rem 1rem;
  background: transparent;
  border: 1px solid rgba(201,168,76,0.3);
  color: rgba(201,168,76,0.65);
  font-family: var(--font-sans);
  font-size: 0.5rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  border-radius: 2px;
  transition: color 280ms ease, border-color 280ms ease;
  white-space: nowrap;
}

.site-footer__reserve-btn-secondary:hover {
  color: var(--color-gold);
  border-color: rgba(201,168,76,0.55);
}

/* Bottom */
.site-footer__bottom {
  padding-top: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

@media (min-width: 768px) {
  .site-footer__bottom {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }
}

.site-footer__copyright,
.site-footer__sub {
  font-family: var(--font-sans);
  font-size: 0.6875rem;
  color: rgba(242,235,224,0.28);
  letter-spacing: 0.02em;
}

.site-footer__network {
  padding-top: 2.5rem;
  padding-bottom: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

@media (min-width: 640px) {
  .site-footer__network {
    flex-direction: row;
    align-items: center;
    gap: 2rem;
  }
}

.site-footer__network-label {
  font-family: var(--font-sans);
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(242,235,224,0.30);
  transition: color 280ms ease;
  white-space: nowrap;
}

.site-footer__network-label:hover { color: var(--color-gold); }

.site-footer__network-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1.5rem;
}

.site-footer__network-link {
  font-family: var(--font-sans);
  font-size: 0.75rem;
  color: rgba(242,235,224,0.25);
  transition: color 280ms ease;
}

.site-footer__network-link:hover { color: rgba(242,235,224,0.60); }

.site-footer__bottom-right {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.site-footer__lilos-credit {
  font-family: var(--font-sans);
  font-size: 0.8125rem;
  color: rgba(242,235,224,0.50);
  transition: color 280ms ease;
  white-space: nowrap;
}

.site-footer__lilos-credit:hover { color: var(--color-gold); }
</style>
