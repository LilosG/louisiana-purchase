---
// src/components/layout/SiteNav.astro
// Louisiana Purchase — Site Navigation
// Desktop nav shows at 1280px+. Contact in footer only.

interface Props {
  transparent?: boolean;
}

import { getSingleton } from '../../content/siteData';
const navigation = await getSingleton('navigation', 'navigation');

const { transparent = true } = Astro.props;
const currentPath = Astro.url.pathname;

const phoneRaw = import.meta.env.PUBLIC_VENUE_PHONE || navigation.phoneFallback;
// Formats a US E.164 number (+18586836828) as (858) 683-6828 for display.
// Falls back to the raw value for any non-US-10-digit format rather than showing nothing.
function formatPhone(value: string): string {
  const digits = value.replace(/\D/g, '').replace(/^1/, '');
  if (digits.length !== 10) return value;
  return `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6)}`;
}
const phoneDisplay = formatPhone(phoneRaw);

const navLinks = Array.isArray(navigation.desktopLinks) ? navigation.desktopLinks : [];

const mobileLinks = [
  ...(navigation.mobileExtraLinks?.home ? [navigation.mobileExtraLinks.home] : []),
  ...navLinks,
  ...(navigation.mobileExtraLinks?.contact ? [navigation.mobileExtraLinks.contact] : []),
];
---

<header
  id="site-nav"
  role="banner"
  aria-label={navigation.ariaLabels.header}
  class:list={['site-nav', { 'site-nav--transparent': transparent }]}
>
  <div class="site-nav__inner">

    <a href="/" class="site-nav__brand" aria-label={navigation.wordmark.homeAriaLabel}>
      <span class="site-nav__wordmark-top">{navigation.wordmark.top}</span>
      <span class="site-nav__wordmark-bottom">{navigation.wordmark.bottom}</span>
    </a>

    <nav role="navigation" aria-label={navigation.ariaLabels.mainNavigation} class="site-nav__links">
      <ul role="list">
        {navLinks.map((link: { href: string; label: string }) => (
          <li>
            <a
              href={link.href}
              class:list={['site-nav__link', {
                'site-nav__link--active': currentPath === link.href || currentPath.startsWith(link.href + '/')
              }]}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-nav__ctas">
      <a
        href={`tel:${phoneRaw}`}
        class="site-nav__cta-phone"
        aria-label={`Call Louisiana Purchase at ${phoneDisplay}`}
      >
        {phoneDisplay}
      </a>
      <a
        href={import.meta.env.PUBLIC_ORDER_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="site-nav__cta-order"
        aria-label={navigation.ariaLabels.order}
        set:text={`\n${navigation.ctaLabels.order}\n`}
      ></a>
      <a
        href={import.meta.env.PUBLIC_RESERVATIONS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="site-nav__cta-reserve"
        aria-label={navigation.ariaLabels.reserve}
        set:text={`\n${navigation.ctaLabels.reserve}\n`}
      ></a>
    </div>

    <button
      id="nav-mobile-toggle"
      type="button"
      class="site-nav__mobile-toggle"
      aria-controls="nav-mobile-drawer"
      aria-expanded="false"
      aria-label={navigation.ariaLabels.openMenu}
    >
      <span class="site-nav__burger-line" aria-hidden="true"></span>
      <span class="site-nav__burger-line" aria-hidden="true"></span>
      <span class="site-nav__burger-line site-nav__burger-line--short" aria-hidden="true"></span>
    </button>

  </div>
</header>

<div
  id="nav-mobile-drawer"
  role="dialog"
  aria-modal="true"
  aria-label={navigation.ariaLabels.navigationMenu}
  aria-hidden="true"
  class="site-nav__drawer"
>
  <nav role="navigation" aria-label={navigation.ariaLabels.mobileNavigation} class="site-nav__drawer-nav">
    <ul role="list" class="site-nav__drawer-list">
      {mobileLinks.map((link) => (
        <li>
          <a href={link.href} class="site-nav__drawer-link">{link.label}</a>
        </li>
      ))}
    </ul>
    <div class="site-nav__drawer-ctas">
      <a href={import.meta.env.PUBLIC_RESERVATIONS_URL} target="_blank" rel="noopener noreferrer" class="site-nav__drawer-reserve" set:text={`\n${navigation.ctaLabels.reserveTable}\n`}></a>
      <a href={import.meta.env.PUBLIC_ORDER_URL} target="_blank" rel="noopener noreferrer" class="site-nav__drawer-order" set:text={`\n${navigation.ctaLabels.orderOnline}\n`}></a>
      <a href={`tel:${phoneRaw}`} class="site-nav__drawer-phone">
        {phoneDisplay}
      </a>
    </div>
  </nav>
</div>

<style>
.site-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 40;
  transition: background 400ms cubic-bezier(0.25,0.1,0.25,1),
              border-color 400ms cubic-bezier(0.25,0.1,0.25,1),
              box-shadow 400ms cubic-bezier(0.25,0.1,0.25,1);
  background: rgba(10,8,6,0.96);
  border-bottom: 1px solid rgba(201,168,76,0.12);
}

.site-nav--transparent {
  background: transparent;
  border-bottom-color: transparent;
}

.site-nav--scrolled {
  background: rgba(10,8,6,0.97) !important;
  border-bottom-color: rgba(201,168,76,0.15) !important;
  box-shadow: 0 4px 32px rgba(10,8,6,0.60);
}

.site-nav__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 2rem;
  height: 5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

/* Wordmark */
.site-nav__brand {
  display: flex;
  flex-direction: column;
  line-height: 1;
  gap: 0.1em;
  flex-shrink: 0;
}

.site-nav__wordmark-top {
  font-family: var(--font-sans);
  font-size: 0.5rem;
  font-weight: 500;
  letter-spacing: 0.36em;
  text-transform: uppercase;
  color: rgba(201,168,76,0.75);
  transition: color 280ms ease;
}

.site-nav__wordmark-bottom {
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 400;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-parchment);
  transition: color 280ms ease;
}

.site-nav__brand:hover .site-nav__wordmark-top,
.site-nav__brand:hover .site-nav__wordmark-bottom { color: var(--color-gold); }

/* Desktop links — show at 1280px */
.site-nav__links {
  display: none;
  flex: 1;
  justify-content: center;
}

@media (min-width: 1280px) {
  .site-nav__links { display: flex; }
}

.site-nav__links ul {
  display: flex;
  align-items: center;
  gap: 2.25rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.site-nav__link {
  font-family: var(--font-sans);
  font-size: 0.8125rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(242,235,224,0.72);
  transition: color 280ms ease;
  white-space: nowrap;
}

.site-nav__link:hover,
.site-nav__link--active { color: var(--color-gold); }

/* Desktop CTAs — show at 1280px */
.site-nav__ctas {
  display: none;
  align-items: center;
  gap: 0.875rem;
  flex-shrink: 0;
}

@media (min-width: 1280px) {
  .site-nav__ctas { display: flex; }
}

.site-nav__cta-order {
  font-family: var(--font-sans);
  font-size: 0.8125rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(242,235,224,0.72);
  transition: color 280ms ease;
  padding: 0.5rem;
}

.site-nav__cta-order:hover { color: var(--color-parchment); }

.site-nav__cta-phone {
  font-family: var(--font-sans);
  font-size: 0.8125rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  color: rgba(242,235,224,0.55);
  transition: color 280ms ease;
  padding: 0.5rem;
  white-space: nowrap;
}

.site-nav__cta-phone:hover { color: var(--color-gold); }

.site-nav__cta-reserve {
  font-family: var(--font-sans);
  font-size: 0.8125rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-obsidian);
  background: var(--color-gold);
  padding: 0.75rem 1.625rem;
  border-radius: 2px;
  transition: background 280ms ease;
  white-space: nowrap;
}

.site-nav__cta-reserve:hover { background: var(--color-gold-light); }

/* Mobile toggle — hidden at 1280px */
.site-nav__mobile-toggle {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 2.5rem;
  height: 2.5rem;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
}

@media (min-width: 1280px) {
  .site-nav__mobile-toggle { display: none; }
}

.site-nav__burger-line {
  display: block;
  width: 100%;
  height: 1px;
  background: var(--color-parchment);
  transition: all 300ms cubic-bezier(0.76,0,0.24,1);
  transform-origin: center;
}

.site-nav__burger-line--short { width: 60%; }

.site-nav__mobile-toggle[aria-expanded="true"] .site-nav__burger-line:nth-child(1) {
  transform: translateY(6px) rotate(45deg);
}
.site-nav__mobile-toggle[aria-expanded="true"] .site-nav__burger-line:nth-child(2) {
  transform: translateY(-6px) rotate(-45deg);
}
.site-nav__mobile-toggle[aria-expanded="true"] .site-nav__burger-line--short {
  opacity: 0;
  transform: scaleX(0);
}

/* Mobile drawer */
.site-nav__drawer {
  position: fixed;
  inset: 0;
  z-index: 39;
  background: rgba(10,8,6,0.98);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 400ms cubic-bezier(0.76,0,0.24,1);
}

.site-nav__drawer.is-open {
  opacity: 1;
  pointer-events: auto;
}

.site-nav__drawer-nav {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
  width: 100%;
  padding: 2rem;
}

.site-nav__drawer-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.375rem;
  text-align: center;
}

.site-nav__drawer-link {
  font-family: var(--font-serif);
  font-size: clamp(1.75rem, 5vw, 2.5rem);
  font-weight: 300;
  color: var(--color-parchment);
  letter-spacing: -0.01em;
  transition: color 280ms ease;
  line-height: 1.3;
}

.site-nav__drawer-link:hover { color: var(--color-gold); }

.site-nav__drawer-ctas {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(201,168,76,0.15);
  width: 100%;
  max-width: 280px;
}

.site-nav__drawer-reserve {
  width: 100%;
  text-align: center;
  font-family: var(--font-sans);
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--color-obsidian);
  background: var(--color-gold);
  padding: 1rem;
  border-radius: 2px;
  transition: background 280ms ease;
}

.site-nav__drawer-reserve:hover { background: var(--color-gold-light); }

.site-nav__drawer-order {
  font-family: var(--font-sans);
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.20em;
  text-transform: uppercase;
  color: rgba(242,235,224,0.55);
  transition: color 280ms ease;
}

.site-nav__drawer-order:hover { color: var(--color-parchment); }

.site-nav__drawer-phone {
  font-family: var(--font-sans);
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.20em;
  color: rgba(242,235,224,0.4);
  transition: color 280ms ease;
}

.site-nav__drawer-phone:hover { color: var(--color-gold); }
</style>

<script>
(function initNav(): void {
  const nav    = document.getElementById('site-nav') as HTMLElement | null;
  const toggle = document.getElementById('nav-mobile-toggle') as HTMLButtonElement | null;
  const drawer = document.getElementById('nav-mobile-drawer') as HTMLElement | null;

  if (!nav || !toggle || !drawer) return;

  const isTransparent = nav.classList.contains('site-nav--transparent');
  if (isTransparent) {
    let ticking = false;
    const onScroll = (): void => {
      if (!ticking) {
        requestAnimationFrame((): void => {
          nav.classList.toggle('site-nav--scrolled', window.scrollY > 60);
          ticking = false;
        });
        ticking = true;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  function openDrawer(): void {
    drawer!.classList.add('is-open');
    drawer!.setAttribute('aria-hidden', 'false');
    toggle!.setAttribute('aria-expanded', 'true');
    toggle!.setAttribute('aria-label', 'Close navigation menu');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer(): void {
    drawer!.classList.remove('is-open');
    drawer!.setAttribute('aria-hidden', 'true');
    toggle!.setAttribute('aria-expanded', 'false');
    toggle!.setAttribute('aria-label', 'Open navigation menu');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', (): void => {
    toggle.getAttribute('aria-expanded') === 'true' ? closeDrawer() : openDrawer();
  });

  drawer.querySelectorAll('a').forEach((link: HTMLAnchorElement): void => {
    link.addEventListener('click', closeDrawer);
  });

  document.addEventListener('keydown', (e: KeyboardEvent): void => {
    if (e.key === 'Escape') closeDrawer();
  });
})();
</script>
