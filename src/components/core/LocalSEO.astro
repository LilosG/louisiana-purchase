---
// src/components/core/LocalSEO.astro
// Louisiana Purchase — Centralized SEO & AEO Engine
//
// Responsibilities:
//   1. Injects <meta> tags: title, description, canonical, OG, Twitter Card
//   2. Programmatically builds and outputs JSON-LD Restaurant schema
//   3. Outputs breadcrumb JSON-LD when breadcrumbs are supplied
//   4. Manages robots directives
//
// This component is consumed exclusively by src/layouts/Layout.astro.
// It must never be imported directly into page files.

import type { PageSeoProps, VenueSchemaConfig, BreadcrumbItem } from '../../types/seo';
import {
  VENUE_NAME,
  CANONICAL_DOMAIN,
  VENUE_ADDRESS,
  VENUE_GEO,
  VENUE_PHONE_FALLBACK,
  VENUE_EMAIL_FALLBACK,
  VENUE_SOCIAL,
  REGULAR_HOURS,
  VENUE_DEFAULT_IMAGE,
} from '../../data/venue';

interface Props extends PageSeoProps {}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType    = 'website',
  noindex   = false,
  schema,
  breadcrumbs,
} = Astro.props;

// ─── Venue Identity ─────────────────────────────────────────────────────────
// These values are static brand truths. They live here, not in environment
// variables, because they are structural identity facts — not operational
// platform endpoints that rotate.

const VENUE: VenueSchemaConfig = {
  name:               VENUE_NAME,
  type:               'Restaurant',
  description:        "An opulent French Quarter-inspired cocktail lounge and Creole dining destination in North Park, San Diego. Renowned for fire-charred oysters, craft Praline Old Fashioneds, and Chef Quinnton Austin's elevated Louisiana culinary program.",
  url:                import.meta.env.PUBLIC_SITE_URL || CANONICAL_DOMAIN,
  phone:              import.meta.env.PUBLIC_VENUE_PHONE || VENUE_PHONE_FALLBACK,
  email:              import.meta.env.PUBLIC_VENUE_EMAIL || VENUE_EMAIL_FALLBACK,
  address: {
    street:   VENUE_ADDRESS.street,
    city:     VENUE_ADDRESS.city,
    state:    VENUE_ADDRESS.state,
    zip:      VENUE_ADDRESS.zip,
    country:  VENUE_ADDRESS.country,
  },
  geo: {
    latitude:  VENUE_GEO.latitude,
    longitude: VENUE_GEO.longitude,
  },
  hours: REGULAR_HOURS,
  cuisines: [
    'Creole',
    'Louisiana',
    'Southern American',
    'New Orleans',
    'Cajun',
    'Cocktail Bar',
    'American',
  ],
  priceRange:           '$$$',
  image:                VENUE_DEFAULT_IMAGE,
  logo:                 '/logo.png',
  acceptsReservations:  true,
  hasMenu:              `${CANONICAL_DOMAIN}/menu`,
};

// ─── Canonical URL Resolution ────────────────────────────────────────────────
const siteUrl   = import.meta.env.PUBLIC_SITE_URL?.replace(/\/$/, '') || CANONICAL_DOMAIN;
const pagePath  = Astro.url.pathname;
const resolvedCanonical = canonical
  ? `${siteUrl}${canonical}`
  : `${siteUrl}${pagePath}`;

// ─── OG Image Resolution ─────────────────────────────────────────────────────
const resolvedOgImage = ogImage
  ? `${siteUrl}${ogImage}`
  : `${siteUrl}${VENUE_DEFAULT_IMAGE}`;

// ─── JSON-LD: Restaurant Schema ──────────────────────────────────────────────
const restaurantSchema: Record<string, unknown> = {
  '@context':   'https://schema.org',
  '@type':      VENUE.type,
  name:         VENUE.name,
  description:  VENUE.description,
  url:          VENUE.url,
  telephone:    VENUE.phone,
  email:        VENUE.email,
  priceRange:   VENUE.priceRange,
  image:        `${siteUrl}${VENUE.image}`,
  logo: {
    '@type': 'ImageObject',
    url:     `${siteUrl}${VENUE.logo}`,
  },
  address: {
    '@type':           'PostalAddress',
    streetAddress:     VENUE.address.street,
    addressLocality:   VENUE.address.city,
    addressRegion:     VENUE.address.state,
    postalCode:        VENUE.address.zip,
    addressCountry:    VENUE.address.country,
  },
  geo: {
    '@type':    'GeoCoordinates',
    latitude:   VENUE.geo.latitude,
    longitude:  VENUE.geo.longitude,
  },
  openingHoursSpecification: VENUE.hours.map((h) => ({
    '@type':     'OpeningHoursSpecification',
    dayOfWeek:   `https://schema.org/${h.dayOfWeek}`,
    opens:       h.opens,
    closes:      h.closes,
  })),
  servesCuisine:        VENUE.cuisines,
  hasMenu:              VENUE.hasMenu,
  acceptsReservations:  VENUE.acceptsReservations,
  currenciesAccepted:   'USD',
  paymentAccepted:      'Cash, Credit Card',
  amenityFeature: [
    { '@type': 'LocationFeatureSpecification', name: 'Full Bar',            value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Outdoor Seating',     value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Private Dining Room', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Live Jazz',           value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Weekend Brunch',      value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Reservations',        value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Cocktail Bar',        value: true },
  ],
  sameAs: [
    VENUE_SOCIAL.instagram,
    VENUE_SOCIAL.facebook,
  ],
};

// ─── JSON-LD: Breadcrumb Schema ───────────────────────────────────────────────
const buildBreadcrumbSchema = (items: BreadcrumbItem[]): Record<string, unknown> => ({
  '@context':        'https://schema.org',
  '@type':           'BreadcrumbList',
  itemListElement:   items.map((item) => ({
    '@type':   'ListItem',
    position:  item.position,
    name:      item.name,
    item:      `${siteUrl}${item.url}`,
  })),
});

// ─── Page Title Formatting ────────────────────────────────────────────────────
const BRAND_SUFFIX = 'Louisiana Purchase | North Park, San Diego';
const formattedTitle = title.includes('Louisiana Purchase')
  ? title
  : `${title} — ${BRAND_SUFFIX}`;
---

<!-- ─── Primary Meta Tags ─────────────────────────────────────────────── -->
<title>{formattedTitle}</title>
<meta name="description" content={description} />
<meta name="author"      content="Louisiana Purchase" />
<link rel="canonical"    href={resolvedCanonical} />

{noindex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
}

<!-- ─── Open Graph ───────────────────────────────────────────────────── -->
<meta property="og:type"        content={ogType} />
<meta property="og:url"         content={resolvedCanonical} />
<meta property="og:title"       content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image"       content={resolvedOgImage} />
<meta property="og:image:alt"   content={`${VENUE.name} — ${VENUE.address.city}`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name"   content={VENUE.name} />
<meta property="og:locale"      content="en_US" />

<!-- ─── Twitter Card ────────────────────────────────────────────────── -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={formattedTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={resolvedOgImage} />
<meta name="twitter:image:alt"   content={`${VENUE.name} — ${VENUE.address.city}`} />

<!-- ─── Geo & Local Business Meta ──────────────────────────────────── -->
<meta name="geo.region"      content="US-CA" />
<meta name="geo.placename"   content="San Diego, California" />
<meta name="geo.position"    content={`${VENUE.geo.latitude};${VENUE.geo.longitude}`} />
<meta name="ICBM"            content={`${VENUE.geo.latitude}, ${VENUE.geo.longitude}`} />

<!-- ─── JSON-LD: Restaurant Structured Data ─────────────────────────── -->
<script type="application/ld+json" set:html={JSON.stringify(restaurantSchema, null, 0)} />

<!-- ─── JSON-LD: Breadcrumbs (conditional) ──────────────────────────── -->
{breadcrumbs && breadcrumbs.length > 0 && (
  <script
    type="application/ld+json"
    set:html={JSON.stringify(buildBreadcrumbSchema(breadcrumbs), null, 0)}
  />
)}

<!-- ─── JSON-LD: Page-Specific Override (conditional) ───────────────── -->
{schema && (
  Array.isArray(schema)
    ? schema.map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s, null, 0)} />
      ))
    : <script type="application/ld+json" set:html={JSON.stringify(schema, null, 0)} />
)}
