---
// src/layouts/Layout.astro
// Louisiana Purchase — Master Document Wrapper

import SiteNav from '../components/layout/SiteNav.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import LocalSEO from '../components/core/LocalSEO.astro';
import Analytics from '../components/layout/Analytics.astro';
import type { PageSeoProps } from '../types/seo';

import '../styles/global.css';

interface Props extends PageSeoProps {
  transparentNav?: boolean;
}

const { transparentNav = true, ...seoProps } = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <LocalSEO {...seoProps} />

    <link rel="icon"             type="image/svg+xml"  href="/favicon.svg" />
    <link rel="icon"             type="image/png"      href="/favicon-96x96.png" sizes="96x96" />
    <link rel="apple-touch-icon"                       href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest"         href="/site.webmanifest" />
    <meta name="theme-color"     content="#0A0806" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Cormorant+SC:wght@300;400;500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@300;400&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Cormorant+SC:wght@300;400;500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@300;400&display=swap" />
    </noscript>

    <Analytics />
  </head>

  <body class="bg-obsidian text-parchment font-sans antialiased overflow-x-hidden">

    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-gold-500 focus:text-obsidian focus:text-sm focus:rounded-sm">
      Skip to main content
    </a>

    <SiteNav transparent={transparentNav} />

    <main id="main-content" role="main" class="site-main">
      <slot />
    </main>

    <SiteFooter />

  </body>
</html>

<script>
  (function initScrollAnimations(): void {
    const targets = document.querySelectorAll<HTMLElement>('.animate-on-scroll, .reveal');
    if (!targets.length || !('IntersectionObserver' in window)) return;
    const observer = new IntersectionObserver(
      (entries: IntersectionObserverEntry[]): void => {
        entries.forEach((entry): void => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05, rootMargin: '0px 0px -20px 0px' }
    );
    targets.forEach((el): void => observer.observe(el));
  })();
</script>
